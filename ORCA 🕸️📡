interface CodeFinding {
  id:          string;
  rule_id:     string;
  severity:    "CRITICAL" | "HIGH" | "MEDIUM" | "LOW" | "INFO";
  category:    string;
  message:     string;
  line:        number | null;
  col:         number | null;
  snippet:     string;
  remediation: string;
  cwe:         string | null;
  owasp:       string | null;
}

interface CodeAnalysisResult {
  file_name:   string;
  language:    string;
  lines:       number;
  blank_lines: number;
  comment_lines:number;
  findings:    CodeFinding[];
  summary:     Record<string, number>;
  risk_score:  number;
  complexity:  "low" | "medium" | "high" | "critical";
  analyzed_at: string;
}

