// Update throughput window every minute
setInterval(() => {
  const cutoff = Date.now() - 60_000;
  const idx    = throughputWindow.findIndex(t => t > cutoff);
  if (idx > 0) throughputWindow.splice(0, idx);
  taskMetrics.throughput_per_min = throughputWindow.length;
}, 60_000);

