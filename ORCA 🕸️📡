app.post("/api/files/upload", rateLimitMiddleware("upload"), async (req, res) => {
  const token = req.headers["x-owner-token"] as string;
  const email = verifySession(token);
  if (!email) return res.status(401).json({ error: "Authentication required" });
  if (!hasPermission(email, "file:upload")) return res.status(403).json({ error: "file:upload permission required" });

  try {
    const { fields, files } = await parseMultipart(req);
    if (!files.length) return res.status(400).json({ error: "No file found in request" });
    const tags = fields.tags ? fields.tags.split(",").map(t => t.trim()) : [];

    const results = await Promise.all(
      files.map(file => saveUploadedFile(file, email, tags))
