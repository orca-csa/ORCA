type Permission =
  | "scan:read"      | "scan:write"
  | "ioc:read"       | "ioc:write"
  | "incident:read"  | "incident:write"
  | "report:read"    | "report:write"
  | "agent:read"     | "agent:manage"
  | "customer:read"  | "customer:write"
  | "config:read"    | "config:write"
  | "apikey:read"    | "apikey:write"
  | "audit:read"
  | "plugin:manage"
  | "worker:manage"
  | "cache:manage"
  | "role:manage"
  | "file:upload"    | "file:read"
  | "code:analyze"
  | "cli:execute"
  | "user:read"      | "user:write"
  | "metrics:read"
  | "task:manage"
  | "*";

type RoleName = "owner" | "admin" | "analyst" | "viewer" | "api_user" | "auditor";

const ROLE_PERMISSIONS: Record<RoleName, Permission[]> = {
  owner: ["*"],
  admin: [
    "scan:read","scan:write","ioc:read","ioc:write","incident:read","incident:write",
    "report:read","report:write","agent:read","agent:manage","customer:read","customer:write",
    "config:read","apikey:read","audit:read","cache:manage","worker:manage","task:manage",
    "file:upload","file:read","code:analyze","cli:execute","user:read","user:write","metrics:read",
  ],
  analyst: [
    "scan:read","scan:write","ioc:read","ioc:write","incident:read","incident:write",
    "report:read","agent:read","audit:read","file:upload","file:read","code:analyze","metrics:read",
  ],
  viewer: [
    "scan:read","ioc:read","incident:read","report:read","agent:read","file:read","metrics:read",
  ],
  api_user: [
    "scan:read","scan:write","ioc:read","report:read","file:upload","code:analyze",
  ],
  auditor: [
    "scan:read","ioc:read","incident:read","report:read","audit:read","metrics:read","user:read",
  ],
};

interface RoleRecord {
  id:          string;
  email:       string;
  role:        RoleName;
  granted_by:  string;
  created_at:  string;
  expires_at:  string | null;
  reason:      string;
}

const roleStoreV5 = new Map<string, RoleRecord>(); // email → role

function grantRole(email: string, role: RoleName, grantedBy: string, expiresAt?: number, reason = ""): RoleRecord {
  const record: RoleRecord = {
    id:          uuidv4(),
    email:       email.toLowerCase(),
    role,
    granted_by:  grantedBy,
    created_at:  new Date().toISOString(),
    expires_at:  expiresAt ? new Date(expiresAt).toISOString() : null,
    reason,
  };
  roleStoreV5.set(email.toLowerCase(), record);
  activityTracker.record(grantedBy, "role:granted", { email, role });
  return record;
}

function revokeRole(email: string, revokedBy: string): boolean {
  const existed = roleStoreV5.has(email.toLowerCase());
  roleStoreV5.delete(email.toLowerCase());
  if (existed) activityTracker.record(revokedBy, "role:revoked", { email });
  return existed;
}

function getRole(email: string): RoleName {
  if (isOwner(email)) return "owner";
  const record = roleStoreV5.get(email.toLowerCase());
  if (!record) return "viewer";
  if (record.expires_at && Date.now() > new Date(record.expires_at).getTime()) {
    roleStoreV5.delete(email.toLowerCase());
    return "viewer";
  }
  return record.role;
}

function hasPermission(email: string, permission: Permission): boolean {
  const role  = getRole(email);
  const perms = ROLE_PERMISSIONS[role] || [];
  return perms.includes("*") || perms.includes(permission);
}

function requirePermission(permission: Permission) {
  return (req: Request, res: Response, next: NextFunction) => {
    const token = req.headers["x-owner-token"] as string;
    if (!token) return res.status(401).json({ error: "Authentication required" });
    const email = verifySession(token);
    if (!email) return res.status(401).json({ error: "Invalid or expired session" });
    if (!hasPermission(email, permission)) {
      return res.status(403).json({
        error:       "Permission denied",
        required:    permission,
        your_role:   getRole(email),
        your_email:  email,
      });
    }
    (req as any).authEmail = email;
    (req as any).authRole  = getRole(email);
    next();
  };
}

