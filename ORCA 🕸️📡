async function lookupAbuseIPDB(ip: string): Promise<any> {
  const key = process.env.ABUSEIPDB_API_KEY || runtimeKeys.get("abuseipdb") || "";
  if (!key) return { available: false, reason: "Add ABUSEIPDB_API_KEY env var" };
  return new Promise(resolve => {
    const path = `/api/v2/check?ipAddress=${encodeURIComponent(ip)}&maxAgeInDays=90&verbose`;
    const req  = https.get({ hostname: "api.abuseipdb.com", path, headers: { "Key": key, "Accept": "application/json" } }, res => {
      let d = ""; res.on("data", c => d += c);
      res.on("end", () => {
        try {
          const j = JSON.parse(d).data;
          resolve({
            available:        true,
            source:           "AbuseIPDB",
            ip:               j.ipAddress,
            abuse_score:      j.abuseConfidenceScore,   // 0-100
            total_reports:    j.totalReports,
            last_reported_at: j.lastReportedAt,
            country:          j.countryCode,
            isp:              j.isp,
            is_tor:           j.isTor,
            is_whitelisted:   j.isWhitelisted,
            usage_type:       j.usageType,
            domain:           j.domain,
            severity:         j.abuseConfidenceScore >= 80 ? "CRITICAL" : j.abuseConfidenceScore >= 50 ? "HIGH" : j.abuseConfidenceScore >= 20 ? "MEDIUM" : "LOW",
          });
        } catch { resolve({ available: false, reason: "AbuseIPDB parse error" }); }
      });
    });
    req.setTimeout(8000, () => { req.destroy(); resolve({ available: false, reason: "AbuseIPDB timeout" }); });
    req.on("error", () => resolve({ available: false, reason: "AbuseIPDB network error" }));
  });
}

async function lookupVirusTotal(value: string): Promise<any> {
  const key = process.env.VIRUSTOTAL_API_KEY || runtimeKeys.get("virustotal") || "";
  if (!key) return { available: false, reason: "Add VIRUSTOTAL_API_KEY env var" };

  // Determine resource type
  const isIP     = /^(\d{1,3}\.){3}\d{1,3}$/.test(value);
  const isDomain = /^[a-z0-9][a-z0-9\-\.]+\.[a-z]{2,}$/i.test(value) && !isIP;
  const isHash   = /^[a-f0-9]{32,64}$/i.test(value);
  let vtPath = "";
  if (isIP)     vtPath = `/api/v3/ip_addresses/${value}`;
  else if (isDomain) vtPath = `/api/v3/domains/${value}`;
  else if (isHash)   vtPath = `/api/v3/files/${value}`;
  else vtPath = `/api/v3/urls/${Buffer.from(value).toString("base64url")}`;

  return new Promise(resolve => {
    const req = https.get({ hostname: "www.virustotal.com", path: vtPath, headers: { "x-apikey": key, "Accept": "application/json" } }, res => {
      let d = ""; res.on("data", c => d += c);
      res.on("end", () => {
        try {
          const j = JSON.parse(d);
          const attr = j.data?.attributes;
          if (!attr) return resolve({ available: false, reason: d.slice(0, 200) });
          const stats    = attr.last_analysis_stats || {};
          const total    = Object.values(stats).reduce((a: any, b: any) => a + b, 0) as number;
          const malicious = (stats.malicious || 0) as number;
          resolve({
            available:        true,
            source:           "VirusTotal",
            value,
            type:             isIP ? "ip" : isDomain ? "domain" : isHash ? "hash" : "url",
            malicious_count:  malicious,
            total_engines:    total,
            detection_rate:   total > 0 ? `${((malicious / total) * 100).toFixed(1)}%` : "0%",
            reputation:       attr.reputation || 0,
            country:          attr.country || "",
            as_owner:         attr.as_owner || "",
            last_analysis_date: attr.last_analysis_date
              ? new Date(attr.last_analysis_date * 1000).toISOString() : "",
            severity:         malicious >= 10 ? "CRITICAL" : malicious >= 5 ? "HIGH" : malicious >= 1 ? "MEDIUM" : "LOW",
            tags:             attr.tags || [],
          });
        } catch { resolve({ available: false, reason: "VirusTotal parse error" }); }
      });
    });
    req.setTimeout(10000, () => { req.destroy(); resolve({ available: false, reason: "VirusTotal timeout" }); });
    req.on("error", () => resolve({ available: false, reason: "VirusTotal network error" }));
  });
}

async function lookupIOCExternal(value: string): Promise<any> {
  const isIP = /^(\d{1,3}\.){3}\d{1,3}$/.test(value);
  const [abuseResult, vtResult] = await Promise.all([
    isIP ? lookupAbuseIPDB(value) : Promise.resolve({ available: false, reason: "AbuseIPDB is IP-only" }),
    lookupVirusTotal(value),
  ]);

  // Auto-add to local IOC store if highly malicious
  const score = abuseResult?.abuse_score || 0;
  const vtMal = vtResult?.malicious_count || 0;
  if (score >= 50 || vtMal >= 5) {
    const severity = (score >= 80 || vtMal >= 10) ? "CRITICAL" : "HIGH";
    addIOC({ value, type: isIP ? "ip" : "domain", severity, confidence: Math.min(0.99, (score / 100) || (vtMal / 20)), source: "external_lookup", tags: ["auto-added"] });
  }

  return { value, abuseipdb: abuseResult, virustotal: vtResult, lookup_time: new Date().toISOString() };
}

function parseLine(raw:string):any{
