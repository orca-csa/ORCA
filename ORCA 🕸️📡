type TaskStatus   = "pending" | "running" | "completed" | "failed" | "retrying" | "cancelled";
type TaskPriority = "critical" | "high" | "normal" | "low";

interface Task {
  id:           string;
  type:         string;
  payload:      any;
  priority:     TaskPriority;
  status:       TaskStatus;
  attempts:     number;
  max_attempts: number;
  result:       any;
  error:        string | null;
  created_at:   string;
  started_at:   string | null;
  completed_at: string | null;
  scheduled_at: string | null;
  owner_email:  string | null;
  tags:         string[];
  duration_ms:  number | null;
}

const PRIORITY_ORDER: Record<TaskPriority, number> = { critical: 4, high: 3, normal: 2, low: 1 };
const taskQueue    = new Map<string, Task>();
const taskHandlers = new Map<string, (payload: any) => Promise<any>>();
const taskMetrics  = {
  total: 0, completed: 0, failed: 0, cancelled: 0,
  avg_duration_ms: 0, throughput_per_min: 0,
};
const throughputWindow: number[] = [];

function enqueueTask(
  type: string,
  payload: any,
  opts: {
    priority?:    TaskPriority;
    max_attempts?: number;
    delay_ms?:    number;
    owner?:       string;
    tags?:        string[];
  } = {}
): Task {
  const task: Task = {
    id:           uuidv4(),
    type,
    payload,
    priority:     opts.priority     || "normal",
    status:       "pending",
    attempts:     0,
    max_attempts: opts.max_attempts || 3,
    result:       null,
    error:        null,
    created_at:   new Date().toISOString(),
    started_at:   null,
    completed_at: null,
    scheduled_at: opts.delay_ms ? new Date(Date.now() + opts.delay_ms).toISOString() : null,
    owner_email:  opts.owner || null,
    tags:         opts.tags  || [],
    duration_ms:  null,
  };
  taskQueue.set(task.id, task);
  taskMetrics.total++;
  return task;
}

function registerTaskHandler(type: string, handler: (payload: any) => Promise<any>): void {
  taskHandlers.set(type, handler);
}

function getNextTask(): Task | null {
  const now     = Date.now();
  const pending = Array.from(taskQueue.values())
    .filter(t =>
      t.status === "pending" &&
      (!t.scheduled_at || new Date(t.scheduled_at).getTime() <= now)
    )
    .sort((a, b) =>
      PRIORITY_ORDER[b.priority] - PRIORITY_ORDER[a.priority] ||
      new Date(a.created_at).getTime() - new Date(b.created_at).getTime()
    );
  return pending[0] || null;
}

async function processTask(task: Task): Promise<void> {
  const handler = taskHandlers.get(task.type);
  if (!handler) {
    task.status = "failed";
    task.error  = `No handler registered for task type: "${task.type}"`;
    taskMetrics.failed++;
    return;
  }

  task.status     = "running";
  task.started_at = new Date().toISOString();
  task.attempts++;

  const start = Date.now();
  try {
    task.result       = await handler(task.payload);
    task.status       = "completed";
    task.completed_at = new Date().toISOString();
    task.duration_ms  = Date.now() - start;
    taskMetrics.completed++;
    // Exponential moving average for duration
    taskMetrics.avg_duration_ms = taskMetrics.avg_duration_ms === 0
      ? task.duration_ms
      : +(taskMetrics.avg_duration_ms * 0.85 + task.duration_ms * 0.15).toFixed(1);
    throughputWindow.push(Date.now());
    monitoringBus.emit("task:completed", { id: task.id, type: task.type, duration_ms: task.duration_ms });
  } catch (e: any) {
    task.error = String(e);
    if (task.attempts < task.max_attempts) {
      // Exponential backoff
      const delay    = 5_000 * Math.pow(2, task.attempts - 1);
      task.status    = "pending";
      task.scheduled_at = new Date(Date.now() + delay).toISOString();
    } else {
      task.status      = "failed";
      task.completed_at = new Date().toISOString();
      task.duration_ms  = Date.now() - start;
      taskMetrics.failed++;
      monitoringBus.emit("task:failed", { id: task.id, type: task.type, error: task.error, attempts: task.attempts });
    }
  }
}

function cancelTask(id: string): boolean {
  const task = taskQueue.get(id);
  if (!task || task.status === "running" || task.status === "completed") return false;
  task.status = "cancelled";
  taskMetrics.cancelled++;
  return true;
}

function getTasksByStatus(status: TaskStatus, limit = 50): Task[] {
  return Array.from(taskQueue.values()).filter(t => t.status === status).slice(-limit);
}

function purgeCompletedTasks(olderThanMs = 3600_000): number {
  const cutoff = Date.now() - olderThanMs;
  let count    = 0;
  for (const [id, task] of taskQueue) {
    if ((task.status === "completed" || task.status === "cancelled") &&
        new Date(task.created_at).getTime() < cutoff) {
      taskQueue.delete(id); count++;
    }
  }
  return count;
}

