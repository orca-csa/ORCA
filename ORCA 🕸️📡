const DB_DIR  = pathMod.join(process.cwd(), ".orca_db");
const DB_FILE = pathMod.join(DB_DIR, "orca.json");
try { fs.mkdirSync(DB_DIR, { recursive: true }); } catch {}

class OrcaORM {
  public lastSaved  = "";
  private dirty     = false;
  private saving    = false;
  private loadedAt  = "";

  constructor() {
    this.load();
    // Auto-save every 30 seconds if dirty
    setInterval(() => { if (this.dirty && !this.saving) this.save(); }, 30_000);
  }

  load(): void {
    try {
      const raw  = fs.readFileSync(DB_FILE, "utf-8");
      const data = JSON.parse(raw);
      // Restore stores
      for (const [k,v] of Object.entries(data.customers  ||{})) customerDB.set(k, v as any);
      for (const [k,v] of Object.entries(data.iocs        ||{})) iocStore.set(k, v as any);
      for (const [k,v] of Object.entries(data.incidents   ||{})) incidentStore.set(k, v as any);
      for (const [k,v] of Object.entries(data.api_keys    ||{})) apiKeyIndex.set(k, v as string);
      for (const [k,v] of Object.entries(data.assets      ||{})) assetStore.set(k, v as any);
      for (const [k,v] of Object.entries(data.schedules   ||{})) scheduleStore.set(k, v as any);
      for (const [k,v] of Object.entries(data.roles       ||{})) roleStoreV5.set(k, v as any);
      for (const [k,v] of Object.entries(data.users       ||{})) userProfileStore.set(k, v as any);
      for (const [k,v] of Object.entries(data.scans       ||{})) {
        const scan = v as any;
        scanHistoryStore.set(k, scan);
        const email = scan.email;
        if (!scansByEmailStore.has(email)) scansByEmailStore.set(email, []);
        if (!scansByEmailStore.get(email)!.includes(k)) scansByEmailStore.get(email)!.push(k);
      }
      for (const [k,v] of Object.entries(data.files||{})) fileStore.set(k, v as any);
      this.lastSaved = data.last_saved || "";
      this.loadedAt  = new Date().toISOString();
      orcaLog("INFO","orm",`DB loaded: ${customerDB.size} customers, ${iocStore.size} IOCs, ${scanHistoryStore.size} scans, ${assetStore.size} assets`);
    } catch (e: any) {
      if (e.code !== "ENOENT") orcaLog("WARN","orm","DB load failed",e.message);
      else orcaLog("INFO","orm","No existing database — starting fresh");
    }
  }

  save(): void {
    if (this.saving) return;
    this.saving = true;
    try {
      const snapshot = {
        customers:  Object.fromEntries(customerDB),
        iocs:       Object.fromEntries(Array.from(iocStore.entries()).slice(-2000)),
        incidents:  Object.fromEntries(Array.from(incidentStore.entries()).slice(-500)),
        api_keys:   Object.fromEntries(apiKeyIndex),
        assets:     Object.fromEntries(assetStore),
        schedules:  Object.fromEntries(scheduleStore),
        roles:      Object.fromEntries(roleStoreV5),
        users:      Object.fromEntries(userProfileStore),
        scans:      Object.fromEntries(Array.from(scanHistoryStore.entries()).slice(-200)),
        files:      Object.fromEntries(fileStore),
        last_saved: new Date().toISOString(),
        version:    "5.0.0",
      };
      fs.writeFileSync(DB_FILE, JSON.stringify(snapshot, null, 2));
      this.lastSaved = snapshot.last_saved;
      this.dirty     = false;
      monitoringBus.emit("db:saved", { path: DB_FILE, size: fs.statSync(DB_FILE).size, saved_at: this.lastSaved });
    } catch(e) {
      monitoringBus.emit("db:error", { error: String(e) });
      orcaLog("ERROR","orm","DB save failed",String(e));
    } finally { this.saving = false; }
  }

  markDirty(): void { this.dirty = true; }

  stats(): any {
    let fileSize = 0;
    try { fileSize = fs.statSync(DB_FILE).size; } catch {}
    return {
      customers:   customerDB.size,
      iocs:        iocStore.size,
      incidents:   incidentStore.size,
      scans:       scanHistoryStore.size,
      assets:      assetStore.size,
      schedules:   scheduleStore.size,
      roles:       roleStoreV5.size,
      users:       userProfileStore.size,
      files:       fileStore.size,
      last_saved:  this.lastSaved,
      loaded_at:   this.loadedAt,
      db_file:     DB_FILE,
      file_size_kb:+(fileSize/1024).toFixed(1),
      dirty:       this.dirty,
    };
  }

  // Export database as JSON download
  export(): string { return JSON.stringify({ ...this.stats(), exported_at: new Date().toISOString() }, null, 2); }
}

const orcaDB = new OrcaORM();

