];

// Hashed passwords store { email -> hashedPassword }
const ownerPasswords = new Map<string, string>();
const ownerSessions  = new Map<string, { email: string; created_at: string }>();

function hashPassword(password: string, saltHex?: string): string {
  // scrypt with unique per-user salt (fixes static salt vulnerability)
  const salt = saltHex ? Buffer.from(saltHex, "hex") : crypto.randomBytes(16);
  const hash = crypto.scryptSync(password, salt, 64);
  // Store format: saltHex:hashHex
  return salt.toString("hex") + ":" + hash.toString("hex");
}

function verifyPassword(password: string, stored: string): boolean {
  // Handle both legacy static-salt format and new salt:hash format
  if (!stored.includes(":")) {
    // Legacy: re-hash with static salt for migration
    const LEGACY_SALT = "ORCA_PLATFORM_SCRYPT_SALT_2026";
    const legacyHash = crypto.scryptSync(password, LEGACY_SALT, 64).toString("hex");
    return crypto.timingSafeEqual(Buffer.from(stored, "hex"), Buffer.from(legacyHash, "hex"));
  }
  const [saltHex, hashHex] = stored.split(":");
  const hash = crypto.scryptSync(password, Buffer.from(saltHex, "hex"), 64);
  return crypto.timingSafeEqual(hash, Buffer.from(hashHex, "hex"));
}

function createSession(email: string): string {
  const token = uuidv4() + "-" + uuidv4();
  ownerSessions.set(token, { email, created_at: new Date().toISOString() });
  return token;
}

function verifySession(token: string): string | null {
  const session = ownerSessions.get(token);
  return session ? session.email : null;
}

function isOwner(email: string): boolean {
  return OWNER_EMAILS.includes(email.toLowerCase().trim());
}

// Auth middleware for owner-only routes
function ownerOnly(req: Request, res: Response, next: NextFunction) {
  const token = req.headers["x-owner-token"] as string || req.body?.owner_token;
  if (!token) return res.status(401).json({ error: "Owner token required" });
  const email = verifySession(token);
  if (!email) return res.status(401).json({ error: "Invalid or expired session" });
  (req as any).ownerEmail = email;
  next();
}

