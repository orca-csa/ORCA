// CUSTOMER API KEY SYSTEM
// Every subscriber gets their own API key tied to their plan
// ════════════════════════════════════════════════════════════════

interface CustomerRecord {
  email:      string;
  apiKey:     string;
  plan:       "basic" | "pro" | "enterprise";
  assetsUsed: number;
  assetsLimit: number;
  parallelLimit: number;
  apiAccess:  boolean;
  createdAt:  number;
  expiresAt:  number | null;
  active:     boolean;
}

const customerDB = new Map<string, CustomerRecord>(); // email → record
const apiKeyIndex = new Map<string, string>();         // apiKey → email

const PLAN_LIMITS = {
  basic:      { assets: 5,   parallel: 2,  apiAccess: false, monthlyUSD: 65  },
  pro:        { assets: 50,  parallel: 5,  apiAccess: true,  monthlyUSD: 255 },
  enterprise: { assets: 500, parallel: 10, apiAccess: true,  monthlyUSD: 712 },
};

function generateApiKey(): string {
  const prefix = "orca";
  const rand = crypto.randomBytes(24).toString("hex");
  return `${prefix}_${rand}`;
}

function createCustomer(email: string, plan: "basic" | "pro" | "enterprise"): CustomerRecord {
  const apiKey = generateApiKey();
  const limits = PLAN_LIMITS[plan];
  const record: CustomerRecord = {
    email:         email.toLowerCase(),
    apiKey,
    plan,
    assetsUsed:    0,
    assetsLimit:   limits.assets,
    parallelLimit: limits.parallel,
    apiAccess:     limits.apiAccess,
    createdAt:     Date.now(),
    expiresAt:     Date.now() + 30 * 24 * 60 * 60 * 1000, // 30 days
    active:        true,
  };
  customerDB.set(record.email, record);
  apiKeyIndex.set(apiKey, record.email);
  return record;
}

function validateCustomerKey(apiKey: string): CustomerRecord | null {
  const email = apiKeyIndex.get(apiKey);
  if (!email) return null;
  const customer = customerDB.get(email);
  if (!customer || !customer.active) return null;
  if (customer.expiresAt && Date.now() > customer.expiresAt) {
    customer.active = false;
    return null;
  }
  return customer;
}

function checkQuota(customer: CustomerRecord): boolean {
  return customer.assetsUsed < customer.assetsLimit;
}

