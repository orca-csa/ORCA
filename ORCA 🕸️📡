// ── 6. PDF REPORT ───────────────────────────────────────────────
function generatePDF(scan: ScanRecord): Promise<Buffer> {
  return new Promise((resolve, reject) => {
    const doc = new PDFDocument({ margin: 50, size: "A4" });
    const chunks: Buffer[] = [];
    doc.on("data", c => chunks.push(c));
    doc.on("end",  () => resolve(Buffer.concat(chunks)));
    doc.on("error", reject);

    const DARK = "#030912", BLUE = "#0066ff", CYAN = "#00d4ff";
    const WHITE = "#ffffff", GRAY = "#4a6a88", RED = "#ff4444", ORA = "#ff8800", YEL = "#ffcc00";

    // Background + Header
    doc.rect(0, 0, doc.page.width, doc.page.height).fill(DARK);
    doc.rect(0, 0, doc.page.width, 90).fill("#050f1e");
    doc.fontSize(28).fillColor(WHITE).font("Helvetica-Bold").text("ORCA", 50, 28, { characterSpacing: 10 });
    doc.fontSize(8).fillColor(CYAN).font("Helvetica").text("CYBER SECURITY PLATFORM", 50, 62, { characterSpacing: 3 });
    doc.fontSize(8).fillColor(GRAY).text("SCAN REPORT", doc.page.width - 160, 62);

    // Meta
    doc.fontSize(18).fillColor(WHITE).font("Helvetica-Bold").text("Scan Report", 50, 110);
    doc.fontSize(9).fillColor(GRAY).font("Helvetica");
    doc.text(`Target    : ${scan.target}`,    50, 140);
    doc.text(`Scan Type : ${scan.scan_type.replace(/_/g," ").toUpperCase()}`, 50, 155);
    doc.text(`Generated : ${new Date().toISOString()}`,  50, 170);
    doc.text(`Scan Date : ${scan.created_at}`, 50, 185);
    doc.text(`Scan ID   : ${scan.id}`,          50, 200);
    doc.text(`Account   : ${scan.email}`,        50, 215);

    // Summary box
    const sumY = 240;
    doc.rect(50, sumY, doc.page.width - 100, 55).fill("#050f1e").stroke("#0d1f33");
    doc.fontSize(7).fillColor(CYAN).text("SUMMARY", 65, sumY + 10, { characterSpacing: 2 });
    let sumX = 65;
    for (const [k, v] of Object.entries(scan.summary || {})) {
      const val = typeof v === "object" ? JSON.stringify(v) : String(v);
      doc.fontSize(16).fillColor(WHITE).font("Helvetica-Bold").text(val.slice(0, 6), sumX, sumY + 22);
      doc.fontSize(7).fillColor(GRAY).font("Helvetica").text(k.replace(/_/g," ").toUpperCase(), sumX, sumY + 42, { characterSpacing: 1 });
      sumX += 120; if (sumX > doc.page.width - 120) break;
    }

    // Findings
    const findings = extractFindings(scan.scan_type, scan.result);
    let y = sumY + 80;
    doc.fontSize(11).fillColor(WHITE).font("Helvetica-Bold").text("Findings", 50, y); y += 20;
    if (!findings.length) { doc.fontSize(9).fillColor(GRAY).font("Helvetica").text("No critical or high findings.", 50, y); y += 20; }
    else {
      for (const f of findings) {
        if (y > doc.page.height - 100) { doc.addPage(); doc.rect(0, 0, doc.page.width, doc.page.height).fill(DARK); y = 50; }
        const col = f.severity === "CRITICAL" ? RED : f.severity === "HIGH" ? ORA : f.severity === "MEDIUM" ? YEL : CYAN;
        doc.rect(50, y, 70, 18).fill(col);
        doc.fontSize(7).fillColor(DARK).font("Helvetica-Bold").text(f.severity, 54, y + 5);
        doc.fontSize(9).fillColor(WHITE).font("Helvetica").text(String(f.title||"").slice(0,60), 130, y + 4);
        doc.fontSize(7).fillColor(GRAY).text(String(f.detail||"").slice(0,80), 130, y + 16);
        if (f.remediation) { doc.fontSize(7).fillColor(CYAN).text(`Fix: ${String(f.remediation).slice(0,80)}`, 130, y + 27); y += 42; }
        else y += 30;
      }
    }

    // Raw summary
    if (y < doc.page.height - 120) {
      y += 10;
      doc.fontSize(11).fillColor(WHITE).font("Helvetica-Bold").text("Raw Summary", 50, y); y += 18;
      doc.fontSize(7).fillColor(GRAY).font("Courier")
        .text(JSON.stringify(scan.summary, null, 2).slice(0, 800), 50, y, { width: doc.page.width - 100 });
    }

    // Footer
    doc.rect(0, doc.page.height - 40, doc.page.width, 40).fill("#050f1e");
    doc.fontSize(7).fillColor(GRAY).font("Helvetica")
      .text(`ORCA Security Platform  ·  ${scan.email}  ·  Confidential`, 50, doc.page.height - 25);
    doc.end();
  });
}

