    const saved  = results.filter(r => !("error" in r)) as UploadedFile[];
    const errors = results.filter(r => "error" in r)    as { error: string }[];

    res.json({
      success:      true,
      uploaded:     saved.length,
      errors:       errors.map(e => e.error),
      files:        saved.map(f => ({ id: f.id, name: f.name, size: f.size, task_id: f.task_id })),
