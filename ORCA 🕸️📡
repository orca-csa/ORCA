    nucleiAvailable = true;
  } catch {}

  // 2. Always run our HTTP header checks as baseline
  const baseFindings = await scanVulnerabilities(target);

  // 3. Enrich CVE findings with CIRCL data
  const enriched = await Promise.all(nucleiFindings.map(async f => {
    if (f.cve_id) {
      const cveData = await lookupCVE(f.cve_id);
      if (cveData) {
        f.cvss_score  = cveData.cvss || f.cvss_score;
        f.description = cveData.summary || f.detail;
        f.published   = cveData.Published || "";
        f.references  = cveData.references?.slice(0, 3) || [];
      }
    }
    return f;
  }));

  const allFindings = [...baseFindings, ...enriched];
  const summary: any = { CRITICAL: 0, HIGH: 0, MEDIUM: 0, LOW: 0, INFO: 0 };
  for (const f of allFindings) summary[f.severity] = (summary[f.severity] || 0) + 1;

  return {
    target, scan_time: new Date().toISOString(),
    duration_ms:      Date.now() - start,
    nuclei_available: nucleiAvailable,
    findings_count:   allFindings.length,
    summary,
    findings:         allFindings,
  };
}

