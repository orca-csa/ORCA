app.post("/api/chat", async (req, res) => {
  const { message, session_id, owner_token } = req.body as { message: string; session_id?: string; owner_token?: string };
  if (!message) return res.status(400).json({ error: "message required" });

  const sessionId = session_id || uuidv4();
  let isOwner_flag = false;
  let ownerEmail: string | undefined;

  if (owner_token) {
    const email = verifySession(owner_token);
    if (email && isOwner(email)) { isOwner_flag = true; ownerEmail = email; }
  }

  try {
    const result = await talkToKing(sessionId, message, isOwner_flag, ownerEmail);
    res.json({ ...result, session_id: sessionId });
  } catch (e) {
    res.status(500).json({ error: String(e) });
  }
});

