interface UserProfile {
  email:        string;
  display_name: string;
  avatar_url:   string | null;
  timezone:     string;
  language:     "en" | "ar" | "fr" | "de" | "zh" | "ru" | "es" | "ja";
  preferences:  Record<string, any>;
  created_at:   string;
  updated_at:   string;
  last_login:   string | null;
  login_count:  number;
  ip_whitelist: string[];
  mfa_enabled:  boolean;
  tags:         string[];
  notes:        string;
}

const userProfileStore = new Map<string, UserProfile>(); // email → profile

function getOrCreateProfile(email: string): UserProfile {
  const key = email.toLowerCase();
  if (!userProfileStore.has(key)) {
    userProfileStore.set(key, {
      email:        key,
      display_name: email.split("@")[0],
      avatar_url:   null,
      timezone:     "UTC",
      language:     "en",
      preferences:  {},
      created_at:   new Date().toISOString(),
      updated_at:   new Date().toISOString(),
      last_login:   null,
      login_count:  0,
      ip_whitelist: [],
      mfa_enabled:  false,
      tags:         [],
      notes:        "",
    });
  }
  return userProfileStore.get(key)!;
}

function updateProfile(email: string, updates: Partial<Omit<UserProfile, "email" | "created_at">>): UserProfile {
  const profile = getOrCreateProfile(email);
  Object.assign(profile, { ...updates, updated_at: new Date().toISOString() });
  return profile;
}

function recordLogin(email: string, ip: string): void {
  const profile = getOrCreateProfile(email);
  profile.last_login  = new Date().toISOString();
  profile.login_count++;
  activityTracker.record(email, "user:login", { ip });
}

function searchUsers(query: string): UserProfile[] {
  return Array.from(userProfileStore.values()).filter(p =>
    p.email.includes(query) || p.display_name.toLowerCase().includes(query.toLowerCase())
  );
}

