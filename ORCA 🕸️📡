type ErrorSeverity = "low" | "medium" | "high" | "critical";

interface OrcaError {
  id:          string;
  code:        string;
  message:     string;
  stack:       string | null;
  context:     any;
  severity:    ErrorSeverity;
  source:      string;
  timestamp:   string;
  resolved:    boolean;
  resolved_by: string | null;
  resolved_at: string | null;
  count:       number;          // deduplicated occurrences
}

const errorStore: OrcaError[] = [];
const MAX_ERRORS    = 2000;
const errorIndex    = new Map<string, OrcaError>(); // fingerprint → error

function fingerprintError(message: string, source: string): string {
  return crypto.createHash("md5").update(`${source}:${message}`).digest("hex");
}

function captureError(
  err:      Error | string,
  context:  any           = {},
  severity: ErrorSeverity = "medium",
  source    = "app"
): OrcaError {
  const message     = typeof err === "string" ? err : err.message;
  const fingerprint = fingerprintError(message, source);
  const existing    = errorIndex.get(fingerprint);

  if (existing) {
    existing.count++;
    existing.timestamp = new Date().toISOString();
    return existing;
  }

  const orcaErr: OrcaError = {
    id:          uuidv4(),
    code:        (err as any)?.code || "ERR_UNKNOWN",
    message,
    stack:       typeof err === "object" ? (err.stack || null) : null,
    context,
    severity,
    source,
    timestamp:   new Date().toISOString(),
    resolved:    false,
    resolved_by: null,
    resolved_at: null,
    count:       1,
  };

  errorStore.push(orcaErr);
  errorIndex.set(fingerprint, orcaErr);
  if (errorStore.length > MAX_ERRORS) {
    const removed = errorStore.shift();
    if (removed) errorIndex.delete(fingerprintError(removed.message, removed.source));
  }

  orcaLog(
    severity === "critical" ? "CRITICAL" : severity === "high" ? "ERROR" : "WARN",
    source, message, context
  );

  if (severity === "critical") {
    monitoringBus.emit("error:critical", orcaErr);
    createNotification("system", "system", { error_id: orcaErr.id, message, source }, "high");
  }

  return orcaErr;
}

function resolveError(id: string, resolvedBy: string): boolean {
  const err = errorStore.find(e => e.id === id);
  if (!err) return false;
  err.resolved    = true;
  err.resolved_by = resolvedBy;
  err.resolved_at = new Date().toISOString();
  return true;
}

// ── Global Error Handler (Express) ───────────────────────────
function globalErrorHandler(err: Error, req: Request, res: Response, _next: NextFunction): void {
  const orcaErr = captureError(err, { path: req.path, method: req.method, ip: getClientIP(req) }, "high", "express");
  res.status(500).json({ error: "Internal server error", error_id: orcaErr.id, message: "An unexpected error occurred" });
}

