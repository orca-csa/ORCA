// L3 Vuln Scanner
async function httpGet(url:string,ms=5000):Promise<any>{
  return new Promise(resolve=>{
    try{const p=new URL(url);const lib=p.protocol==="https:"?https:http;
      const req=lib.get(url,{headers:{"User-Agent":"ORCA-Scanner/3.0"}},(res)=>{let b="";res.on("data",c=>b+=c);res.on("end",()=>resolve({status:res.statusCode,headers:res.headers,body:b.slice(0,50000)}));});
      req.setTimeout(ms,()=>{req.destroy();resolve(null)});req.on("error",()=>resolve(null));}catch{resolve(null);}
  });
}

async function scanVulnerabilities(target:string):Promise<any[]>{
  const findings:any[]=[];const base=target.startsWith("http")?target:`https://${target}`;
  const resp=await httpGet(base);
  if(resp){
    const h=Object.fromEntries(Object.entries(resp.headers).map(([k,v])=>[k.toLowerCase(),v]));
    [["strict-transport-security","Missing HSTS","HIGH"],["x-content-type-options","Missing X-Content-Type","MEDIUM"],["x-frame-options","Missing X-Frame-Options","MEDIUM"],["content-security-policy","Missing CSP","HIGH"]].forEach(([hdr,title,sev])=>{if(!h[hdr])findings.push({id:uuidv4(),type:"missing_header",severity:sev,title,url:base,detail:`${hdr} missing`,remediation:`Add ${hdr}`});});
    if(h["server"]&&/\d+\.\d+/.test(h["server"] as string))findings.push({id:uuidv4(),type:"info_disclosure",severity:"LOW",title:"Server Version Disclosed",url:base,detail:`Server: ${h["server"]}`,remediation:"Obfuscate Server header"});
