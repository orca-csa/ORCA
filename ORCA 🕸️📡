async function callGroq(system: string, user: string, lang = "English"): Promise<string> {
  const key = apiKeys.groq() || runtimeKeys.get("groq") || "";
  if (!key) throw new Error("No Groq key");
  return new Promise((resolve, reject) => {
    const body = JSON.stringify({ model: "llama3-8b-8192", messages: [{ role: "system", content: `${system}\nRespond in: ${lang}` }, { role: "user", content: user }], max_tokens: 1024 });
    const req  = https.request({ hostname: "api.groq.com", path: "/openai/v1/chat/completions", method: "POST", headers: { "Content-Type": "application/json", "Authorization": `Bearer ${key}` } }, (res) => {
      let d = ""; res.on("data", c => d += c); res.on("end", () => { try { resolve(JSON.parse(d).choices?.[0]?.message?.content || ""); } catch { reject(new Error("parse")); } });
    });
    req.on("error", reject); req.setTimeout(15000, () => { req.destroy(); reject(new Error("timeout")); }); req.write(body); req.end();
  });
}

async function callGemini(system: string, user: string, lang = "English"): Promise<string> {
  const key = apiKeys.gemini() || runtimeKeys.get("gemini") || "";
  if (!key) throw new Error("No Gemini key");
