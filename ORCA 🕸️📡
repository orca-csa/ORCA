// SYSTEM 27 — SCHEDULER / CRON JOB SYSTEM
// ════════════════════════════════════════════════════════════════

interface SystemCronJob {
  id:          string;
  name:        string;
  cron_expr:   string;
  description: string;
  enabled:     boolean;
  last_run:    string | null;
  next_run:    string | null;
  run_count:   number;
  fail_count:  number;
  last_error:  string | null;
}

const systemCronJobs = new Map<string, SystemCronJob>();

function registerSystemCron(name: string, cronExpr: string, description: string, handler: () => Promise<void>): SystemCronJob {
  const id  = uuidv4();
  const job: SystemCronJob = {
    id, name, cron_expr: cronExpr, description,
    enabled: true, last_run: null, next_run: null,
    run_count: 0, fail_count: 0, last_error: null,
  };
  systemCronJobs.set(id, job);

  cron.schedule(cronExpr, async () => {
    if (!job.enabled) return;
    job.last_run = new Date().toISOString();
    try {
      await handler();
      job.run_count++;
      monitoringBus.emit("schedule:run", { id, name });
      orcaLog("DEBUG","scheduler",`${name} ran successfully`);
    } catch(e) {
      job.fail_count++;
      job.last_error = String(e);
      monitoringBus.emit("schedule:failed", { id, name, error: String(e) });
      orcaLog("ERROR","scheduler",`${name} failed`,String(e));
    }
  });

  return job;
}

