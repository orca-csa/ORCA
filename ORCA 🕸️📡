interface MetricPoint { timestamp: number; value: number; }
const metricsTimeSeries = new Map<string, MetricPoint[]>();
const MAX_TS_POINTS     = 1440; // 24h @ 1-min resolution

function recordMetric(name: string, value: number): void {
  if (!metricsTimeSeries.has(name)) metricsTimeSeries.set(name, []);
  const series = metricsTimeSeries.get(name)!;
  series.push({ timestamp: Date.now(), value });
  if (series.length > MAX_TS_POINTS) series.shift();
}

function getMetricSeries(name: string, lastN?: number): MetricPoint[] {
  const series = metricsTimeSeries.get(name) || [];
  return lastN ? series.slice(-lastN) : series;
}

function getMetricsSummary(name: string, lastN = 60): any {
  const series = getMetricSeries(name, lastN);
  if (!series.length) return null;
  const values = series.map(p => p.value);
  return {
    name, points: series.length,
    current: values[values.length-1],
    mean:    +Stats.mean(values).toFixed(2),
    min:     Math.min(...values),
    max:     Math.max(...values),
    p95:     +Stats.percentile(values,95).toFixed(2),
    trend:   values.length >= 2 ? (values[values.length-1] > values[0] ? "up" : values[values.length-1] < values[0] ? "down" : "stable") : "unknown",
  };
}

