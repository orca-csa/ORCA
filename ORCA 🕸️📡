// 4 ANALYSIS ENGINES — ORCA Service Architecture
// ────────────────────────────────────────────────────────────────
// Backend  : 4 Engines  (run real scans using existing functions)
// Features : 50 Features (extracted from engine results)
// Frontend : 4 Services  (shown to user, each expands to features)
//
// Each service route runs its engine once, then extracts the
// specific feature slice the user requested.  No duplicate scans.
// ════════════════════════════════════════════════════════════════

// ────────────────────────────────────────────────────────────────
// ENGINE 1 — Website Security Analysis  (15 features)
// Uses: httpGet · scanVulnerabilities · nucleiScan · scanHost
// ────────────────────────────────────────────────────────────────
async function engine1_websiteSecurity(target: string): Promise<any> {
  const cacheKey_e1 = `e1:${target}`;
  const cached_e1 = orcaCache.scan.get(cacheKey_e1);
  if (cached_e1) return { ...cached_e1, from_cache: true };

  const base   = target.startsWith("http") ? target : `https://${target}`;
  const domain = (() => { try { return new URL(base).hostname; } catch { return target; } })();
  const start  = Date.now();

  // Run all scans in parallel — one pass, all data collected
  const [httpResp, vulnFindings, nucleiResult, portResult] = await Promise.allSettled([
    httpGet(base, 8000),
    scanVulnerabilities(target),
    nucleiScan(target),
    scanHost(domain, COMMON_PORTS, 1500),
  ]);

  const http    = httpResp.status    === "fulfilled" ? httpResp.value    : null;
  const vulns   = vulnFindings.status === "fulfilled" ? vulnFindings.value : [];
  const nuclei  = nucleiResult.status === "fulfilled" ? nucleiResult.value : { findings: [], findings_count: 0, summary: {} };
  const ports   = portResult.status   === "fulfilled" ? portResult.value   : { open_ports: [], risk_summary: {} };

  const headers   = http ? Object.fromEntries(Object.entries(http.headers).map(([k,v]) => [k.toLowerCase(), v])) : {};
  const allFinds  = [...(vulns as any[]), ...(nuclei.findings || [])];
  const sevCount  = allFinds.reduce((a: any, f: any) => { a[f.severity] = (a[f.severity] || 0) + 1; return a; }, { CRITICAL:0, HIGH:0, MEDIUM:0, LOW:0, INFO:0 });

  // ── SSL via HTTPS HEAD request ──────────────────────────────
  const sslInfo: any = await new Promise(resolve => {
    try {
      const req = https.request({ host: domain, port: 443, method: "HEAD", rejectUnauthorized: false },
        (res: any) => {
          const cert = (res.socket as any).getPeerCertificate?.() || {};
          resolve({
            valid: !!(res.socket as any).authorized || true,
            issuer:  cert.issuer?.O || "Unknown",
            subject: cert.subject?.CN || domain,
            valid_from: cert.valid_from || null,
            valid_to:   cert.valid_to   || null,
            bits:       cert.bits       || null,
            protocol:   (res.socket as any).getProtocol?.() || null,
          });
        });
      req.setTimeout(5000, () => { req.destroy(); resolve({ valid: false, error: "timeout" }); });
      req.on("error", () => resolve({ valid: false, error: "unreachable" }));
      req.end();
    } catch { resolve({ valid: false, error: "exception" }); }
  });

  // ── Security header checks ──────────────────────────────────
  const SECURITY_HEADERS = [
    "strict-transport-security", "content-security-policy", "x-frame-options",
    "x-content-type-options", "x-xss-protection", "referrer-policy",
    "permissions-policy", "cache-control",
  ];
  const presentHeaders  = SECURITY_HEADERS.filter(h => !!headers[h]);
  const missingHeaders  = SECURITY_HEADERS.filter(h => !headers[h]);
  const headerScore     = Math.round((presentHeaders.length / SECURITY_HEADERS.length) * 100);

  // ── HTTPS check ─────────────────────────────────────────────
  const httpsEnabled  = base.startsWith("https");
  const hstsEnabled   = !!headers["strict-transport-security"];
  const httpsRedirect = !httpsEnabled ? false : true;

  // ── Cookie analysis ─────────────────────────────────────────
  const rawCookies: string[] = Array.isArray(headers["set-cookie"]) ? headers["set-cookie"] as string[] : headers["set-cookie"] ? [headers["set-cookie"] as string] : [];
  const cookieAnalysis = rawCookies.map((c: string) => ({
    raw:      c.split(";")[0],
    secure:   /secure/i.test(c),
    httponly: /httponly/i.test(c),
    samesite: /samesite/i.test(c),
  }));
  const insecureCookies = cookieAnalysis.filter((c: any) => !c.secure || !c.httponly);

  // ── Suspicious file detection (from vuln findings) ──────────
  const suspiciousFiles = allFinds.filter((f: any) => f.type === "exposed");

  // ── Malicious script detection ──────────────────────────────
  const maliciousScripts: any[] = [];
  if (http?.body) {
    const body = String(http.body);
    const patterns = [
      { re: /eval\s*\(/g,                  label: "eval() usage" },
      { re: /document\.write\s*\(/g,       label: "document.write()" },
      { re: /base64_decode|atob\s*\(/g,    label: "Base64 decode in JS" },
      { re: /fromCharCode/g,               label: "String.fromCharCode obfuscation" },
      { re: /\bunescape\s*\(/g,            label: "unescape() call" },
    ];
    for (const { re, label } of patterns) {
      const matches = body.match(re);
      if (matches) maliciousScripts.push({ pattern: label, occurrences: matches.length });
    }
  }

  // ── Malware indicators (from nuclei + vuln findings) ────────
  const malwareIndicators = allFinds.filter((f: any) =>
    f.type === "nuclei" || (f.severity === "CRITICAL" || f.severity === "HIGH")
  );

  // ── Server info ──────────────────────────────────────────────
  const serverHeader  = headers["server"]  as string || "Not disclosed";
  const poweredBy     = headers["x-powered-by"] as string || "Not disclosed";
  const serverExposed = /\d+\.\d+/.test(serverHeader);

  // ── Overall trust score ──────────────────────────────────────
  const deductions =
    (sevCount.CRITICAL || 0) * 20 +
    (sevCount.HIGH     || 0) * 10 +
    (sevCount.MEDIUM   || 0) *  5 +
    missingHeaders.length      *  4 +
    insecureCookies.length     *  3 +
    maliciousScripts.length    *  8;
  const trustScore = Math.max(0, 100 - deductions);

  // ── Risk level ───────────────────────────────────────────────
  const riskLevel = sevCount.CRITICAL > 0 ? "CRITICAL"
    : sevCount.HIGH > 0      ? "HIGH"
    : sevCount.MEDIUM > 0    ? "MEDIUM"
    : sevCount.LOW > 0       ? "LOW" : "SAFE";

  const result = {
    engine:      "website_security",
    target,
    scan_time:   new Date().toISOString(),
    duration_ms: Date.now() - start,

    // ── 15 feature slices ───────────────────────────────────────
    features: {

      // F1 — Website Security Scan
      website_security_scan: {
        label:        "Website Security Scan",
        status_code:  http?.status || null,
        reachable:    !!http,
        risk_level:   riskLevel,
        findings_count: allFinds.length,
        severity_summary: sevCount,
        open_ports:   ports.open_ports?.length || 0,
        port_risks:   ports.risk_summary || {},
      },

      // F2 — Malware Detection
      malware_detection: {
        label:             "Malware Detection",
        malware_found:     malwareIndicators.length > 0,
        indicators_count:  malwareIndicators.length,
        indicators:        malwareIndicators.slice(0, 20),
        risk:              malwareIndicators.length > 0 ? "HIGH" : "LOW",
      },

      // F3 — SSL Certificate Analysis
      ssl_certificate_analysis: {
        label:        "SSL Certificate Analysis",
        https_enabled: httpsEnabled,
        ...sslInfo,
        grade: sslInfo.valid && sslInfo.valid_to
          ? (new Date(sslInfo.valid_to) > new Date(Date.now() + 30*24*60*60*1000) ? "A" : "B")
          : "F",
      },

      // F4 — Security Configuration Check
      security_configuration_check: {
        label:           "Security Configuration Check",
        headers_present: presentHeaders,
        headers_missing: missingHeaders,
        header_score:    headerScore,
        server_header:   serverHeader,
        powered_by:      poweredBy,
        server_version_exposed: serverExposed,
      },

      // F5 — Basic Vulnerability Detection
      basic_vulnerability_detection: {
        label:          "Basic Vulnerability Detection",
        total:          allFinds.length,
        critical:       sevCount.CRITICAL || 0,
        high:           sevCount.HIGH     || 0,
        medium:         sevCount.MEDIUM   || 0,
        low:            sevCount.LOW      || 0,
        info:           sevCount.INFO     || 0,
        findings:       allFinds.slice(0, 30),
        nuclei_used:    nuclei.nuclei_available || false,
      },

      // F6 — Website Trust Evaluation
      website_trust_evaluation: {
        label:       "Website Trust Evaluation",
        trust_score: trustScore,
        grade:       trustScore >= 90 ? "A" : trustScore >= 75 ? "B" : trustScore >= 60 ? "C" : trustScore >= 40 ? "D" : "F",
        verdict:     trustScore >= 75 ? "Trusted" : trustScore >= 50 ? "Moderate Risk" : "High Risk",
        factors: {
          https_enabled:       httpsEnabled,
          hsts_enabled:        hstsEnabled,
          no_critical_vulns:   (sevCount.CRITICAL || 0) === 0,
          secure_headers:      missingHeaders.length === 0,
          secure_cookies:      insecureCookies.length === 0,
          no_malicious_scripts: maliciousScripts.length === 0,
        },
      },

      // F7 — Security Risk Analysis
      security_risk_analysis: {
        label:      "Security Risk Analysis",
        risk_level: riskLevel,
        risk_score: 100 - trustScore,
        top_risks:  allFinds
          .filter((f: any) => ["CRITICAL","HIGH"].includes(f.severity))
          .slice(0, 10)
          .map((f: any) => ({ title: f.title, severity: f.severity, detail: f.detail })),
        recommendations: missingHeaders.map((h: string) => `Add security header: ${h}`),
      },

      // F8 — Suspicious File Detection
      suspicious_file_detection: {
        label:             "Suspicious File Detection",
        suspicious_found:  suspiciousFiles.length > 0,
        count:             suspiciousFiles.length,
        files:             suspiciousFiles.map((f: any) => ({ url: f.url, severity: f.severity, detail: f.detail })),
      },

      // F9 — Malicious Script Detection
      malicious_script_detection: {
        label:           "Malicious Script Detection",
        scripts_found:   maliciousScripts.length > 0,
        count:           maliciousScripts.length,
        patterns:        maliciousScripts,
        risk:            maliciousScripts.length > 0 ? "HIGH" : "SAFE",
      },

      // F10 — Security Headers Analysis
      security_headers_analysis: {
        label:         "Security Headers Analysis",
        score:         headerScore,
        present:       presentHeaders,
        missing:       missingHeaders,
        details:       Object.fromEntries(
          SECURITY_HEADERS.map(h => [h, { present: !!headers[h], value: headers[h] || null }])
        ),
      },

      // F11 — HTTPS Configuration Check
      https_configuration_check: {
        label:          "HTTPS Configuration Check",
        https_enabled:  httpsEnabled,
        hsts_enabled:   hstsEnabled,
        hsts_value:     headers["strict-transport-security"] || null,
        ssl_issuer:     sslInfo.issuer,
        ssl_valid_to:   sslInfo.valid_to,
        grade:          httpsEnabled && hstsEnabled ? "A" : httpsEnabled ? "B" : "F",
      },

      // F12 — Cookie Security Analysis
      cookie_security_analysis: {
        label:            "Cookie Security Analysis",
        total_cookies:    cookieAnalysis.length,
        secure_cookies:   cookieAnalysis.filter((c: any) => c.secure).length,
        insecure_cookies: insecureCookies.length,
        cookies:          cookieAnalysis,
        risk:             insecureCookies.length > 0 ? "MEDIUM" : "LOW",
      },

      // F13 — Security Policy Check
      security_policy_check: {
        label:    "Security Policy Check",
        csp:      { present: !!headers["content-security-policy"], value: headers["content-security-policy"] || null },
        hsts:     { present: !!headers["strict-transport-security"], value: headers["strict-transport-security"] || null },
        referrer: { present: !!headers["referrer-policy"],           value: headers["referrer-policy"] || null },
        permissions:{ present: !!headers["permissions-policy"],      value: headers["permissions-policy"] || null },
        score:    [
          !!headers["content-security-policy"],
          !!headers["strict-transport-security"],
          !!headers["referrer-policy"],
          !!headers["permissions-policy"],
        ].filter(Boolean).length * 25,
      },

      // F14 — Server Protection Evaluation
      server_protection_evaluation: {
        label:            "Server Protection Evaluation",
        server_disclosed: serverExposed,
        server_header:    serverHeader,
        powered_by:       poweredBy,
        open_ports:       ports.open_ports || [],
        risk_ports:       (ports.open_ports || []).filter((p: any) => ["CRITICAL","HIGH"].includes(p.risk)),
        protection_score: serverExposed ? 60 : 90,
      },

      // F15 — Full Website Security Report
      full_website_security_report: {
        label:            "Full Website Security Report",
        target,
        scan_time:        new Date().toISOString(),
        trust_score:      trustScore,
        risk_level:       riskLevel,
        total_findings:   allFinds.length,
        severity_summary: sevCount,
        ssl:              sslInfo,
        headers_score:    headerScore,
        cookies:          { total: cookieAnalysis.length, insecure: insecureCookies.length },
        scripts:          { malicious: maliciousScripts.length },
        suspicious_files: suspiciousFiles.length,
        open_ports:       ports.open_ports?.length || 0,
        top_findings:     allFinds.slice(0, 20),
        recommendations:  [
          ...missingHeaders.map((h: string) => `Add ${h} header`),
          ...(insecureCookies.length > 0   ? ["Secure cookies with HttpOnly and Secure flags"]  : []),
          ...(maliciousScripts.length > 0  ? ["Review and remove obfuscated JavaScript"]         : []),
          ...(suspiciousFiles.length > 0   ? ["Restrict access to sensitive files (.env, .git)"] : []),
          ...(!httpsEnabled                ? ["Enable HTTPS/SSL on your website"]                 : []),
        ],
      },
    },
  };
  orcaCache.scan.set(cacheKey_e1, result, 10 * 60_000);
  return result;
}

// ────────────────────────────────────────────────────────────────
// ENGINE 2 — Domain & Infrastructure Analysis  (13 features)
// Uses: dnsRecon · dns.lookup · lookupIOCExternal · scanHost
// ────────────────────────────────────────────────────────────────
async function engine2_domainInfrastructure(target: string): Promise<any> {
  const cacheKey_e2 = `e2:${target}`;
  const cached_e2 = orcaCache.scan.get(cacheKey_e2);
  if (cached_e2) return { ...cached_e2, from_cache: true };

  const domain = (() => { try { return new URL(target.startsWith("http") ? target : `https://${target}`).hostname; } catch { return target; } })();
  const start  = Date.now();

  // Run all lookups in parallel — one pass
  const [dnsResult, iocResult, portResult] = await Promise.allSettled([
    dnsRecon(domain),
    lookupIOCExternal(domain),
    scanHost(domain, COMMON_PORTS, 1500),
  ]);

  const dnsData = dnsResult.status  === "fulfilled" ? dnsResult.value  : { records: {}, subdomains: [], domain };
  const iocData = iocResult.status  === "fulfilled" ? iocResult.value  : { abuseipdb: {}, virustotal: {} };
  const portData = portResult.status === "fulfilled" ? portResult.value : { open_ports: [], ip: domain };

  // ── IP geolocation via free ipapi ───────────────────────────
  const ipAddr: string = portData.ip || domain;
  const geoInfo: any = await new Promise(resolve => {
    const req = https.get(`https://ipapi.co/${ipAddr}/json/`,
      { headers: { "User-Agent": "ORCA-Scanner/3.0" } }, (res: any) => {
        let d = ""; res.on("data", (c: any) => d += c);
        res.on("end", () => { try { resolve(JSON.parse(d)); } catch { resolve({}); } });
      });
    req.setTimeout(6000, () => { req.destroy(); resolve({}); });
    req.on("error", () => resolve({}));
  });

  // ── WHOIS via RDAP (no external dep) ─────────────────────────
  const whoisInfo: any = await new Promise(resolve => {
    const tld = domain.split(".").slice(-1)[0];
    const rdapUrl = `https://rdap.org/domain/${domain}`;
    const req = https.get(rdapUrl, { headers: { "User-Agent": "ORCA-Scanner/3.0" } }, (res: any) => {
      let d = ""; res.on("data", (c: any) => d += c);
      res.on("end", () => { try { resolve(JSON.parse(d)); } catch { resolve({}); } });
    });
    req.setTimeout(8000, () => { req.destroy(); resolve({}); });
    req.on("error", () => resolve({}));
  });

  const registrar   = whoisInfo?.entities?.[0]?.vcardArray?.[1]?.find((e: any[]) => e[0] === "fn")?.[3] || "Unknown";
  const createdDate = whoisInfo?.events?.find((e: any) => e.eventAction === "registration")?.eventDate || null;
  const expiresDate = whoisInfo?.events?.find((e: any) => e.eventAction === "expiration")?.eventDate   || null;

  // ── Domain age ──────────────────────────────────────────────
  const domainAgeDays = createdDate
    ? Math.floor((Date.now() - new Date(createdDate).getTime()) / (1000 * 60 * 60 * 24))
    : null;

  // ── Reputation score ─────────────────────────────────────────
  const abuseScore = iocData.abuseipdb?.abuse_score || 0;
  const vtMalCount = iocData.virustotal?.malicious_count || 0;
  const repScore   = Math.max(0, 100 - abuseScore - vtMalCount * 5);
  const repRisk    = abuseScore > 75 || vtMalCount > 10 ? "CRITICAL"
    : abuseScore > 50 || vtMalCount > 5 ? "HIGH"
    : abuseScore > 25 || vtMalCount > 2 ? "MEDIUM" : "LOW";

  // ── DNS security checks ──────────────────────────────────────
  const txtRecords  = (dnsData.records?.TXT || []) as string[];
  const hasSPF      = txtRecords.some((t: string) => t.startsWith("v=spf1"));
  const hasDMARC    = txtRecords.some((t: string) => t.includes("v=DMARC1"));
  const hasDKIM     = txtRecords.some((t: string) => t.includes("v=DKIM1"));
  const hasCAA      = !!(dnsData.records?.CAA);
  const dnssecEnabled = !!(dnsData.records?.DNSKEY || dnsData.records?.DS);
  const dnsScore    = [hasSPF, hasDMARC, hasDKIM, hasCAA, dnssecEnabled].filter(Boolean).length * 20;

  const result = {
    engine:      "domain_infrastructure",
    target,
    domain,
    scan_time:   new Date().toISOString(),
    duration_ms: Date.now() - start,

    features: {

      // F1 — Domain Analysis
      domain_analysis: {
        label:         "Domain Analysis",
        domain,
        ip:            ipAddr,
        registrar,
        created_date:  createdDate,
        expires_date:  expiresDate,
        age_days:      domainAgeDays,
        nameservers:   dnsData.records?.NS || [],
        tld:           domain.split(".").slice(-1)[0],
      },

      // F2 — DNS Security Check
      dns_security_check: {
        label:          "DNS Security Check",
        score:          dnsScore,
        spf:            hasSPF,
        dmarc:          hasDMARC,
        dkim:           hasDKIM,
        caa:            hasCAA,
        dnssec:         dnssecEnabled,
        missing: [
          !hasSPF    && "SPF record missing",
          !hasDMARC  && "DMARC record missing",
          !hasDKIM   && "DKIM record missing",
          !hasCAA    && "CAA record missing",
          !dnssecEnabled && "DNSSEC not enabled",
        ].filter(Boolean),
      },

      // F3 — DNS Records Analysis
      dns_records_analysis: {
        label:      "DNS Records Analysis",
        domain,
        records:    dnsData.records || {},
        subdomains: dnsData.subdomains || [],
        sub_count:  dnsData.found_subdomains || 0,
        mx_records: dnsData.records?.MX || [],
        a_records:  dnsData.records?.A  || [],
        ns_records: dnsData.records?.NS || [],
        txt_records: txtRecords,
      },

      // F4 — Domain Reputation Check
      domain_reputation_check: {
        label:         "Domain Reputation Check",
        domain,
        reputation_score: repScore,
        risk:          repRisk,
        abuse_score:   abuseScore,
        malicious_vendors: vtMalCount,
        verdict:       repRisk === "LOW" ? "Clean" : repRisk === "MEDIUM" ? "Suspicious" : "Malicious",
        abuseipdb:     iocData.abuseipdb,
        virustotal:    iocData.virustotal,
      },

      // F5 — IP Address Check
      ip_address_check: {
        label:       "IP Address Check",
        ip:          ipAddr,
        domain,
        isp:         geoInfo.org || "Unknown",
        asn:         geoInfo.asn || "Unknown",
        abuse_score: abuseScore,
        ioc_in_store: iocStore.has(ipAddr.toLowerCase()),
      },

      // F6 — Server Location Analysis
      server_location_analysis: {
        label:    "Server Location Analysis",
        ip:       ipAddr,
        country:  geoInfo.country_name || "Unknown",
        country_code: geoInfo.country_code || null,
        region:   geoInfo.region || null,
        city:     geoInfo.city   || null,
        latitude: geoInfo.latitude  || null,
        longitude: geoInfo.longitude || null,
        timezone: geoInfo.timezone  || null,
      },

      // F7 — Hosting Provider Analysis
      hosting_provider_analysis: {
        label:    "Hosting Provider Analysis",
        provider: geoInfo.org  || "Unknown",
        asn:      geoInfo.asn  || "Unknown",
        ip:       ipAddr,
        country:  geoInfo.country_name || "Unknown",
        open_ports: portData.open_ports?.length || 0,
        port_risk:  portData.risk_summary || {},
      },

      // F8 — Domain History Check
      domain_history_check: {
        label:        "Domain History Check",
        domain,
        created_date: createdDate,
        expires_date: expiresDate,
        age_days:     domainAgeDays,
        registrar,
        whois_status: whoisInfo?.status || [],
        age_risk:     domainAgeDays !== null && domainAgeDays < 30 ? "HIGH" : domainAgeDays !== null && domainAgeDays < 180 ? "MEDIUM" : "LOW",
      },

      // F9 — Related Domains Analysis
      related_domains_analysis: {
        label:      "Related Domains Analysis",
        domain,
        subdomains: dnsData.subdomains || [],
        sub_count:  dnsData.found_subdomains || 0,
        nameservers: dnsData.records?.NS || [],
        mx_hosts:   (dnsData.records?.MX || []).map((mx: string) => mx.split(" ").slice(-1)[0]),
      },

      // F10 — WHOIS Information Analysis
      whois_information_analysis: {
        label:        "WHOIS Information Analysis",
        domain,
        registrar,
        created_date: createdDate,
        expires_date: expiresDate,
        nameservers:  dnsData.records?.NS || [],
        status:       whoisInfo?.status || [],
        age_days:     domainAgeDays,
        rdap_raw:     whoisInfo,
      },

      // F11 — Infrastructure Security Check
      infrastructure_security_check: {
        label:       "Infrastructure Security Check",
        ip:          ipAddr,
        open_ports:  portData.open_ports || [],
        risk_ports:  (portData.open_ports || []).filter((p: any) => ["CRITICAL","HIGH"].includes(p.risk)),
        risk_summary: portData.risk_summary || {},
        dns_score:   dnsScore,
        rep_risk:    repRisk,
        overall_risk: repRisk === "CRITICAL" || (portData.risk_summary?.CRITICAL || 0) > 0 ? "CRITICAL"
          : repRisk === "HIGH" || (portData.risk_summary?.HIGH || 0) > 2 ? "HIGH" : "MEDIUM",
      },

      // F12 — Connected Networks Analysis
      connected_networks_analysis: {
        label:    "Connected Networks Analysis",
        ip:       ipAddr,
        asn:      geoInfo.asn       || "Unknown",
        provider: geoInfo.org       || "Unknown",
        country:  geoInfo.country_name || "Unknown",
        subdomains: dnsData.subdomains || [],
        mx_hosts:  (dnsData.records?.MX || []).map((mx: string) => mx.split(" ").slice(-1)[0]),
        ns_providers: dnsData.records?.NS || [],
      },

      // F13 — Infrastructure Report
      infrastructure_report: {
        label:       "Infrastructure Report",
        domain,
        ip:          ipAddr,
        scan_time:   new Date().toISOString(),
        registrar,
        created_date: createdDate,
        expires_date: expiresDate,
        age_days:    domainAgeDays,
        location:    { country: geoInfo.country_name, city: geoInfo.city, isp: geoInfo.org },
        dns_score:   dnsScore,
        rep_score:   repScore,
        rep_risk:    repRisk,
        open_ports:  portData.open_ports?.length || 0,
        subdomains:  dnsData.found_subdomains || 0,
        recommendations: [
          !hasSPF    && "Add SPF DNS record to prevent email spoofing",
          !hasDMARC  && "Add DMARC DNS record for email authentication",
          !hasDKIM   && "Configure DKIM for email signing",
          !hasCAA    && "Add CAA record to restrict certificate issuance",
          !dnssecEnabled && "Enable DNSSEC to protect DNS integrity",
          repRisk !== "LOW" && `Domain has ${repRisk} reputation — investigate abuse reports`,
        ].filter(Boolean),
      },
    },
  };
  orcaCache.scan.set(cacheKey_e2, result, 10 * 60_000);
  return result;
}

// ────────────────────────────────────────────────────────────────
// ENGINE 3 — Threat & Attack Analysis  (12 features)
// Uses: lookupIOCExternal · scanVulnerabilities · httpGet · iocStore
// ────────────────────────────────────────────────────────────────
async function engine3_threatAttack(target: string): Promise<any> {
  const cacheKey_e3 = `e3:${target}`;
  const cached_e3 = orcaCache.scan.get(cacheKey_e3);
  if (cached_e3) return { ...cached_e3, from_cache: true };

  const base   = target.startsWith("http") ? target : `https://${target}`;
  const domain = (() => { try { return new URL(base).hostname; } catch { return target; } })();
  const start  = Date.now();

  const [httpResp, vulnRes, iocRes, portRes] = await Promise.allSettled([
    httpGet(base, 8000),
    scanVulnerabilities(target),
    lookupIOCExternal(domain),
    scanHost(domain, COMMON_PORTS, 1500),
  ]);

  const http    = httpResp.status === "fulfilled" ? httpResp.value    : null;
  const vulns   = vulnRes.status  === "fulfilled" ? vulnRes.value     : [];
  const ioc     = iocRes.status   === "fulfilled" ? iocRes.value      : {};
  const ports   = portRes.status  === "fulfilled" ? portRes.value     : { open_ports: [], ip: domain };

  const abuseScore = ioc.abuseipdb?.abuse_score || 0;
  const vtMalCount = ioc.virustotal?.malicious_count || 0;
  const headers    = http ? Object.fromEntries(Object.entries(http.headers).map(([k,v]) => [k.toLowerCase(),v])) : {};
  const body       = http?.body ? String(http.body) : "";

  // ── Phishing indicators ──────────────────────────────────────
  const phishingSignals: string[] = [];
  if (!headers["strict-transport-security"])  phishingSignals.push("No HSTS header");
  if (!headers["content-security-policy"])    phishingSignals.push("No CSP header");
  if (abuseScore > 30)   phishingSignals.push(`AbuseIPDB score: ${abuseScore}`);
  if (vtMalCount > 0)    phishingSignals.push(`VirusTotal detections: ${vtMalCount}`);
  if (/login|signin|verify|account|secure|update.*password/i.test(domain)) phishingSignals.push("Phishing-like domain keywords");
  if (/paypal|apple|google|microsoft|amazon/i.test(domain) && !domain.includes("paypal.com") && !domain.includes("apple.com")) phishingSignals.push("Brand impersonation in domain");
  const phishingRisk = phishingSignals.length >= 3 ? "HIGH" : phishingSignals.length >= 1 ? "MEDIUM" : "LOW";

  // ── Suspicious links in page ─────────────────────────────────
  const linkPattern = /href=["']([^"']+)["']/gi;
  const allLinks: string[] = [];
  let m;
  while ((m = linkPattern.exec(body)) !== null) allLinks.push(m[1]);
  const suspiciousLinks = allLinks.filter(l =>
    /\.(exe|bat|sh|ps1|vbs|zip|rar|7z|jar|apk)(\?|$)/i.test(l) ||
    /bit\.ly|tinyurl|goo\.gl|ow\.ly/i.test(l) ||
    /data:text|javascript:/i.test(l)
  ).slice(0, 20);

  // ── Attack patterns from vuln findings ──────────────────────
  const attackPatterns = (vulns as any[]).map((f: any) => ({
    type:     f.type,
    title:    f.title,
    severity: f.severity,
    url:      f.url,
  }));

  // ── Bot / crawler detection from headers ────────────────────
  const botSignals: string[] = [];
  if (!headers["x-robots-tag"] && !body.includes("robots"))   botSignals.push("No robots.txt enforcement");
  if (headers["server"] && /nginx|apache/i.test(headers["server"] as string)) botSignals.push("Default server banner visible (easy fingerprinting)");
  if (!headers["x-rate-limit-limit"] && !headers["x-ratelimit-limit"]) botSignals.push("No rate-limit headers detected");

  // ── DDoS risk assessment ────────────────────────────────────
  const ddosRiskFactors: string[] = [];
  const riskyPorts = (ports.open_ports || []).filter((p: any) => ["CRITICAL","HIGH"].includes(p.risk));
  if (riskyPorts.length > 3) ddosRiskFactors.push(`${riskyPorts.length} high-risk ports exposed`);
  if (!headers["strict-transport-security"]) ddosRiskFactors.push("No HSTS — amplification risk");
  if (abuseScore > 50) ddosRiskFactors.push("IP previously reported for abuse");

  // ── Intrusion attempt indicators ────────────────────────────
  const intrusionIndicators = (vulns as any[]).filter((f: any) =>
    ["exposed","missing_header","info_disclosure"].includes(f.type)
  );

  // ── Overall threat level ────────────────────────────────────
  const threatScore = Math.min(100,
    abuseScore * 0.4 +
    vtMalCount * 5 +
    phishingSignals.length * 8 +
    suspiciousLinks.length * 4 +
    riskyPorts.length * 6
  );
  const threatLevel = threatScore >= 75 ? "CRITICAL" : threatScore >= 50 ? "HIGH" : threatScore >= 25 ? "MEDIUM" : "LOW";

  const result = {
    engine:      "threat_attack",
    target,
    domain,
    scan_time:   new Date().toISOString(),
    duration_ms: Date.now() - start,

    features: {

      // F1 — Phishing Attack Detection
      phishing_attack_detection: {
        label:         "Phishing Attack Detection",
        risk:          phishingRisk,
        signals:       phishingSignals,
        signal_count:  phishingSignals.length,
        abuse_score:   abuseScore,
        vt_malicious:  vtMalCount,
      },

      // F2 — Suspicious Link Analysis
      suspicious_link_analysis: {
        label:           "Suspicious Link Analysis",
        total_links:     allLinks.length,
        suspicious_count: suspiciousLinks.length,
        suspicious_links: suspiciousLinks,
        risk:             suspiciousLinks.length > 5 ? "HIGH" : suspiciousLinks.length > 0 ? "MEDIUM" : "LOW",
      },

      // F3 — Malware Threat Analysis
      malware_threat_analysis: {
        label:           "Malware Threat Analysis",
        malicious_score: abuseScore,
        vt_detections:   vtMalCount,
        in_ioc_store:    iocStore.has(domain.toLowerCase()),
        abuseipdb:       ioc.abuseipdb || {},
        virustotal:      ioc.virustotal || {},
        verdict:         vtMalCount > 10 || abuseScore > 75 ? "Malicious"
          : vtMalCount > 2  || abuseScore > 25  ? "Suspicious" : "Clean",
      },

      // F4 — Intrusion Attempt Detection
      intrusion_attempt_detection: {
        label:         "Intrusion Attempt Detection",
        indicators:    intrusionIndicators,
        count:         intrusionIndicators.length,
        exposed_paths: intrusionIndicators.filter((f: any) => f.type === "exposed").map((f: any) => f.url),
        risk:          intrusionIndicators.length > 3 ? "HIGH" : intrusionIndicators.length > 0 ? "MEDIUM" : "LOW",
      },

      // F5 — Attack Pattern Analysis
      attack_pattern_analysis: {
        label:    "Attack Pattern Analysis",
        patterns: attackPatterns,
        count:    attackPatterns.length,
        types:    [...new Set(attackPatterns.map((p: any) => p.type))],
        top_severity: attackPatterns.sort((a: any, b: any) => {
          const order: any = { CRITICAL:0, HIGH:1, MEDIUM:2, LOW:3, INFO:4 };
          return (order[a.severity] || 4) - (order[b.severity] || 4);
        }).slice(0, 5),
      },

      // F6 — Malicious Bot Detection
      malicious_bot_detection: {
        label:       "Malicious Bot Detection",
        bot_signals: botSignals,
        count:       botSignals.length,
        risk:        botSignals.length >= 3 ? "HIGH" : botSignals.length >= 1 ? "MEDIUM" : "LOW",
        recommendations: [
          "Implement rate limiting",
          "Add CAPTCHA on sensitive pages",
          "Configure robots.txt",
          "Use a WAF to filter bot traffic",
        ],
      },

      // F7 — Suspicious Traffic Analysis
      suspicious_traffic_analysis: {
        label:         "Suspicious Traffic Analysis",
        abuse_score:   abuseScore,
        vt_malicious:  vtMalCount,
        risky_ports:   riskyPorts,
        risk:          threatLevel,
        ioc_reports:   ioc.abuseipdb?.reports || [],
      },

      // F8 — Potential DDoS Detection
      potential_ddos_detection: {
        label:        "Potential DDoS Detection",
        risk_factors: ddosRiskFactors,
        count:        ddosRiskFactors.length,
        risk:         ddosRiskFactors.length >= 2 ? "HIGH" : ddosRiskFactors.length === 1 ? "MEDIUM" : "LOW",
        exposed_ports: riskyPorts,
      },

      // F9 — Attack Behavior Analysis
      attack_behavior_analysis: {
        label:           "Attack Behavior Analysis",
        threat_score:    Math.round(threatScore),
        threat_level:    threatLevel,
        phishing_risk:   phishingRisk,
        malware_risk:    vtMalCount > 5 ? "HIGH" : vtMalCount > 0 ? "MEDIUM" : "LOW",
        intrusion_risk:  intrusionIndicators.length > 3 ? "HIGH" : "LOW",
        combined_signals: [
          ...phishingSignals,
          ...botSignals,
          ...ddosRiskFactors,
        ],
      },

      // F10 — Threat Source Analysis
      threat_source_analysis: {
        label:       "Threat Source Analysis",
        domain,
        ip:          ports.ip || domain,
        abuse_reports: ioc.abuseipdb?.reports?.slice(0, 5) || [],
        vt_sources:  ioc.virustotal?.sources || [],
        ioc_store:   iocStore.has(domain.toLowerCase())
          ? { found: true, entry: iocStore.get(domain.toLowerCase()) }
          : { found: false },
      },

      // F11 — Risk Level Evaluation
      risk_level_evaluation: {
        label:       "Risk Level Evaluation",
        threat_score: Math.round(threatScore),
        threat_level: threatLevel,
        breakdown: {
          reputation:  Math.round(abuseScore * 0.4),
          vt_score:    vtMalCount * 5,
          phishing:    phishingSignals.length * 8,
          links:       suspiciousLinks.length * 4,
          ports:       riskyPorts.length * 6,
        },
        verdict: threatLevel === "CRITICAL" ? "Highly Dangerous — Avoid"
          : threatLevel === "HIGH"   ? "Dangerous — Exercise Caution"
          : threatLevel === "MEDIUM" ? "Suspicious — Monitor Closely"
          : "Low Risk — Generally Safe",
      },

      // F12 — Threat Intelligence Report
      threat_intelligence_report: {
        label:        "Threat Intelligence Report",
        target,
        domain,
        scan_time:    new Date().toISOString(),
        threat_score: Math.round(threatScore),
        threat_level: threatLevel,
        phishing:     { risk: phishingRisk, signals: phishingSignals },
        malware:      { vt_detections: vtMalCount, abuse_score: abuseScore },
        intrusion:    { indicators: intrusionIndicators.length, exposed_paths: intrusionIndicators.filter((f: any) => f.type === "exposed").length },
        bots:         { signals: botSignals.length },
        ddos:         { risk_factors: ddosRiskFactors.length },
        top_risks:    [
          ...phishingSignals.map(s => ({ category: "Phishing", detail: s })),
          ...botSignals.map(s     => ({ category: "Bot",      detail: s })),
          ...ddosRiskFactors.map(s => ({ category: "DDoS",    detail: s })),
        ].slice(0, 10),
        recommendations: [
          "Enable HSTS and CSP headers",
          "Monitor AbuseIPDB and VirusTotal regularly",
          "Implement rate limiting and WAF",
          "Remove or restrict exposed sensitive paths",
          "Enable DDoS protection (Cloudflare / similar)",
        ],
      },
    },
  };
  orcaCache.scan.set(cacheKey_e3, result, 10 * 60_000);
  return result;
}

// ────────────────────────────────────────────────────────────────
// ENGINE 4 — AI Reports & Intelligence  (10 features)
// Uses: callAI · engines 1-3 results passed in (or re-run)
// ────────────────────────────────────────────────────────────────
async function engine4_aiIntelligence(target: string): Promise<any> {
  const cacheKey_e4 = `e4:${target}`;
  const cached_e4 = orcaCache.scan.get(cacheKey_e4);
  if (cached_e4) return { ...cached_e4, from_cache: true };

  const start = Date.now();

  // Engines 1-3 return cached results if called again — no duplicate scans
  const [e1, e2, e3] = await Promise.allSettled([
    engine1_websiteSecurity(target),
    engine2_domainInfrastructure(target),
    engine3_threatAttack(target),
  ]);

  const web    = e1.status === "fulfilled" ? e1.value : null;
  const domain = e2.status === "fulfilled" ? e2.value : null;
  const threat = e3.status === "fulfilled" ? e3.value : null;

  const hasAI = aiReady();

  // Compact context for AI prompts
  const ctx = JSON.stringify({
    target,
    trust_score:   web?.features?.website_trust_evaluation?.trust_score,
    risk_level:    web?.features?.website_security_scan?.risk_level,
    threat_score:  threat?.features?.risk_level_evaluation?.threat_score,
    threat_level:  threat?.features?.risk_level_evaluation?.threat_level,
    rep_score:     domain?.features?.domain_reputation_check?.reputation_score,
    rep_risk:      domain?.features?.domain_reputation_check?.risk,
    open_ports:    web?.features?.server_protection_evaluation?.open_ports?.length,
    total_vulns:   web?.features?.basic_vulnerability_detection?.total,
    top_findings:  web?.features?.basic_vulnerability_detection?.findings?.slice(0,5),
  });

  // Helper: call AI with fallback to static analysis
  const aiOrStatic = async (system: string, prompt: string, fallback: any) => {
    const aiKey = `ai:${target}:${prompt.slice(0, 40)}`;
    const aiCached = orcaCache.ai.get(aiKey);
    if (aiCached) return aiCached;
    if (!hasAI) return fallback;
    try {
      const r = await callAI(system, prompt);
      if (r) { orcaCache.ai.set(aiKey, r, 5 * 60_000); return r; }
    } catch {}
    return fallback;
  };

  const SYS = "You are ORCA, an expert cybersecurity AI analyst. Be concise and actionable.";

  // AI analyses — run in parallel
  const [
    aiSecReport,
    aiRiskAnalysis,
    aiThreatPrediction,
    aiTrends,
    aiFootprint,
    aiExposure,
    aiOverview,
    aiFinalReport,
  ] = await Promise.all([
    aiOrStatic(SYS, `Security report for ${target}: ${ctx}`, `Security analysis for ${target} — AI unavailable, static summary provided.`),
    aiOrStatic(SYS, `Risk analysis for ${target}: ${ctx}`, `Risk analysis for ${target} — AI unavailable.`),
    aiOrStatic(SYS, `Predict top 3 future threats for ${target} based on: ${ctx}`, `Threat prediction for ${target} — AI unavailable.`),
    aiOrStatic(SYS, `Security trends for ${target}: ${ctx}`, `Security trends for ${target} — AI unavailable.`),
    aiOrStatic(SYS, `Digital footprint analysis for ${target}: ${ctx}`, `Digital footprint for ${target} — AI unavailable.`),
    aiOrStatic(SYS, `Exposure risk analysis for ${target}: ${ctx}`, `Exposure analysis for ${target} — AI unavailable.`),
    aiOrStatic(SYS, `Infrastructure security overview for ${target}: ${ctx}`, `Infrastructure overview for ${target} — AI unavailable.`),
    aiOrStatic(SYS, `Final comprehensive security intelligence report for ${target}: ${ctx}`, `Final report for ${target} — AI unavailable.`),
  ]);

  // Security score calculation
  const trustScore  = web?.features?.website_trust_evaluation?.trust_score || 50;
  const threatScore = threat?.features?.risk_level_evaluation?.threat_score || 50;
  const repScore    = domain?.features?.domain_reputation_check?.reputation_score || 50;
  const secScore    = Math.round((trustScore * 0.4) + ((100 - threatScore) * 0.35) + (repScore * 0.25));
  const secGrade    = secScore >= 90 ? "A+" : secScore >= 80 ? "A" : secScore >= 70 ? "B" : secScore >= 60 ? "C" : secScore >= 50 ? "D" : "F";

  // Digital reputation
  const digRepScore = Math.round((repScore * 0.6) + (trustScore * 0.4));
  const digRepLevel = digRepScore >= 80 ? "Excellent" : digRepScore >= 60 ? "Good" : digRepScore >= 40 ? "Fair" : "Poor";

  const result = {
    engine:      "ai_intelligence",
    target,
    scan_time:   new Date().toISOString(),
    duration_ms: Date.now() - start,
    ai_used:     hasAI,

    features: {

      // F1 — AI Security Report
      ai_security_report: {
        label:    "AI Security Report",
        target,
        ai_used:  hasAI,
        report:   aiSecReport,
        score:    secScore,
        grade:    secGrade,
      },

      // F2 — AI Risk Analysis
      ai_risk_analysis: {
        label:       "AI Risk Analysis",
        risk_level:  threat?.features?.risk_level_evaluation?.threat_level || "UNKNOWN",
        threat_score: threat?.features?.risk_level_evaluation?.threat_score || 0,
        ai_used:     hasAI,
        analysis:    aiRiskAnalysis,
      },

      // F3 — Security Score Evaluation
      security_score_evaluation: {
        label:       "Security Score Evaluation",
        score:       secScore,
        grade:       secGrade,
        breakdown: {
          website_trust:    trustScore,
          threat_safety:    Math.round(100 - threatScore),
          reputation:       repScore,
        },
        verdict: secScore >= 75 ? "Secure" : secScore >= 50 ? "Moderate Risk" : "High Risk",
      },

      // F4 — Digital Reputation Analysis
      digital_reputation_analysis: {
        label:          "Digital Reputation Analysis",
        score:          digRepScore,
        level:          digRepLevel,
        abuse_score:    domain?.features?.domain_reputation_check?.abuse_score || 0,
        vt_malicious:   domain?.features?.domain_reputation_check?.malicious_vendors || 0,
        trust_score:    trustScore,
        verdict:        digRepLevel,
      },

      // F5 — Threat Prediction Report
      threat_prediction_report: {
        label:      "Threat Prediction Report",
        ai_used:    hasAI,
        prediction: aiThreatPrediction,
        current_risk: threat?.features?.risk_level_evaluation?.threat_level || "UNKNOWN",
        top_active_threats: threat?.features?.threat_intelligence_report?.top_risks?.slice(0,5) || [],
      },

      // F6 — Security Trends Analysis
      security_trends_analysis: {
        label:   "Security Trends Analysis",
        ai_used: hasAI,
        trends:  aiTrends,
        current_stats: {
          total_vulns:  web?.features?.basic_vulnerability_detection?.total || 0,
          open_ports:   web?.features?.server_protection_evaluation?.open_ports?.length || 0,
          threat_score: threat?.features?.risk_level_evaluation?.threat_score || 0,
        },
      },

      // F7 — Digital Footprint Report
      digital_footprint_report: {
        label:      "Digital Footprint Report",
        ai_used:    hasAI,
        footprint:  aiFootprint,
        domain:     domain?.domain,
        subdomains: domain?.features?.related_domains_analysis?.sub_count || 0,
        open_ports: web?.features?.server_protection_evaluation?.open_ports?.length || 0,
        location:   domain?.features?.server_location_analysis,
      },

      // F8 — Exposure Risk Analysis
      exposure_risk_analysis: {
        label:            "Exposure Risk Analysis",
        ai_used:          hasAI,
        analysis:         aiExposure,
        exposed_files:    web?.features?.suspicious_file_detection?.count || 0,
        exposed_ports:    (web?.features?.server_protection_evaluation?.risk_ports || []).length,
        missing_headers:  web?.features?.security_headers_analysis?.missing?.length || 0,
        insecure_cookies: web?.features?.cookie_security_analysis?.insecure_cookies || 0,
        exposure_score:   Math.round(
          ((web?.features?.suspicious_file_detection?.count || 0) * 15) +
          ((web?.features?.server_protection_evaluation?.risk_ports?.length || 0) * 10) +
          ((web?.features?.security_headers_analysis?.missing?.length || 0) * 5)
        ),
      },

      // F9 — Infrastructure Security Overview
      infrastructure_security_overview: {
        label:      "Infrastructure Security Overview",
        ai_used:    hasAI,
        overview:   aiOverview,
        ip:         domain?.features?.ip_address_check?.ip,
        country:    domain?.features?.server_location_analysis?.country,
        provider:   domain?.features?.hosting_provider_analysis?.provider,
        dns_score:  domain?.features?.dns_security_check?.score,
        port_risks: web?.features?.server_protection_evaluation?.risk_ports || [],
      },

      // F10 — Final Security Intelligence Report
      final_security_intelligence_report: {
        label:      "Final Security Intelligence Report",
        target,
        scan_time:  new Date().toISOString(),
        ai_used:    hasAI,
        report:     aiFinalReport,
        scores: {
          security:   secScore,
          trust:      trustScore,
          threat:     Math.round(100 - threatScore),
          reputation: repScore,
          grade:      secGrade,
        },
        summary: {
          risk_level:       threat?.features?.risk_level_evaluation?.threat_level || "UNKNOWN",
          total_vulns:      web?.features?.basic_vulnerability_detection?.total || 0,
          open_ports:       web?.features?.website_security_scan?.open_ports || 0,
          missing_headers:  web?.features?.security_headers_analysis?.missing?.length || 0,
          suspicious_files: web?.features?.suspicious_file_detection?.count || 0,
          phishing_risk:    threat?.features?.phishing_attack_detection?.risk || "UNKNOWN",
          domain_age_days:  domain?.features?.domain_history_check?.age_days,
          subdomains:       domain?.features?.related_domains_analysis?.sub_count || 0,
        },
        recommendations: [
          ...(web?.features?.full_website_security_report?.recommendations || []),
          ...(domain?.features?.infrastructure_report?.recommendations    || []),
          ...(threat?.features?.threat_intelligence_report?.recommendations || []),
        ].slice(0, 15),
      },
    },
  };
  orcaCache.scan.set(cacheKey_e4, result, 10 * 60_000);
  return result;
}

