interface WebhookConfig {
  id:             string;
  email:          string;
  url:            string;
  secret:         string;
  events:         string[];
  active:         boolean;
  created_at:     string;
  delivery_count: number;
  failure_count:  number;
  last_delivered: string | null;
  last_status:    number | null;
  retry_on_fail:  boolean;
}

interface WebhookDelivery {
  id:          string;
  webhook_id:  string;
  event:       string;
  payload:     any;
  status:      "pending" | "delivered" | "failed";
  http_status: number | null;
  attempts:    number;
  delivered_at:string | null;
  created_at:  string;
}

const webhookStore    = new Map<string, WebhookConfig>();      // email → config
const webhookDelivery = new Map<string, WebhookDelivery>();    // delivery_id → record
const MAX_DELIVERIES  = 1000;

function setWebhook(email: string, url: string, events: string[], retryOnFail = true): WebhookConfig {
  const existing = webhookStore.get(email.toLowerCase());
  const wh: WebhookConfig = {
    id:             existing?.id        || uuidv4(),
    email:          email.toLowerCase(),
    url,
    secret:         existing?.secret    || crypto.randomBytes(32).toString("hex"),
    events,
    active:         true,
    created_at:     existing?.created_at || new Date().toISOString(),
    delivery_count: existing?.delivery_count || 0,
    failure_count:  existing?.failure_count  || 0,
    last_delivered: existing?.last_delivered || null,
    last_status:    null,
    retry_on_fail:  retryOnFail,
  };
  webhookStore.set(email.toLowerCase(), wh);
  return wh;
}

async function deliverWebhook(wh: WebhookConfig, payload: any, attempt = 1): Promise<boolean> {
  if (!wh.active) return false;
  const body      = JSON.stringify({ ...payload, delivered_at: new Date().toISOString(), attempt });
  const signature = `sha256=${crypto.createHmac("sha256", wh.secret).update(body).digest("hex")}`;
  const delivery: WebhookDelivery = {
    id: uuidv4(), webhook_id: wh.id,
    event:       payload.event || "unknown",
    payload,
    status:      "pending",
    http_status: null,
    attempts:    attempt,
    delivered_at:null,
    created_at:  new Date().toISOString(),
  };
  // Store delivery record
  webhookDelivery.set(delivery.id, delivery);
  if (webhookDelivery.size > MAX_DELIVERIES) {
    const oldest = webhookDelivery.keys().next().value;
    if (oldest) webhookDelivery.delete(oldest);
  }

  return new Promise(resolve => {
    try {
      const u   = new URL(wh.url);
      const lib = u.protocol === "https:" ? https : http;
      const req = lib.request({
        hostname: u.hostname, port: u.port||undefined,
        path:     u.pathname + u.search, method: "POST",
        headers:  {
          "Content-Type":    "application/json",
          "Content-Length":  Buffer.byteLength(body),
          "X-ORCA-Signature":signature,
          "X-ORCA-Event":    payload.event || "unknown",
          "X-ORCA-Version":  "5.0",
          "User-Agent":      "ORCA-Webhook/5.0",
        },
      }, res2 => {
        delivery.http_status  = res2.statusCode || 0;
        delivery.delivered_at = new Date().toISOString();
        const success         = (res2.statusCode || 0) < 400;
        delivery.status       = success ? "delivered" : "failed";
        wh.last_status        = res2.statusCode || 0;
        if (success) { wh.delivery_count++; wh.last_delivered = delivery.delivered_at; monitoringBus.emit("webhook:delivered",{url:wh.url,event:payload.event}); }
        else {
          wh.failure_count++;
          monitoringBus.emit("webhook:failed", { url:wh.url, event:payload.event, status:res2.statusCode });
          // Retry once after 5s on failure if enabled
          if (wh.retry_on_fail && attempt < 2) setTimeout(() => deliverWebhook(wh, payload, attempt+1), 5000);
        }
        resolve(success);
      });
      req.setTimeout(10_000, () => { req.destroy(); delivery.status="failed"; wh.failure_count++; resolve(false); });
      req.on("error", () => { delivery.status="failed"; wh.failure_count++; resolve(false); });
      req.write(body);
      req.end();
    } catch(e) { delivery.status="failed"; wh.failure_count++; resolve(false); }
  });
}

async function triggerAlerts(email: string, target: string, scan_type: string, result: any, scan_id: string): Promise<void> {
  const findings = extractFindings(scan_type, result);
  const critical = findings.filter((f:any) => f.severity==="CRITICAL"||f.severity==="HIGH");
  if (!critical.length) return;

  // In-app notification
  createNotification(email, "alert", { target, scan_type, critical_count:critical.filter((f:any)=>f.severity==="CRITICAL").length, high_count:critical.filter((f:any)=>f.severity==="HIGH").length }, "high");
  // Email alert
  if (siteConfig.smtp_configured) sendAlertEmail(email, target, scan_type, critical);
  // Webhook
  const wh = webhookStore.get(email.toLowerCase());
  if (wh?.active && (!wh.events.length || wh.events.includes("scan") || wh.events.includes("alert"))) {
    await deliverWebhook(wh, { event:"scan.completed", target, scan_type, scan_id, critical:critical.length, findings_count:findings.length });
  }
}

