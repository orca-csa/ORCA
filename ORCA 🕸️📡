interface GatewayLog {
  id:           string;
  method:       string;
  path:         string;
  status_code:  number;
  duration_ms:  number;
  client_ip:    string;
  api_key:      string | null;
  owner:        boolean;
  user_agent:   string;
  timestamp:    string;
  error:        string | null;
  bytes_sent:   number;
}

const gatewayLogs: GatewayLog[] = [];
const MAX_GATEWAY_LOGS = 5000;

function getClientIP(req: Request): string {
  return (req.headers["x-forwarded-for"] as string)?.split(",")[0]?.trim()
    || req.socket?.remoteAddress
    || "unknown";
}

// ── Gateway Middleware ────────────────────────────────────────
function gatewayMiddleware(req: Request, res: Response, next: NextFunction): void {
  const start  = Date.now();
  const origEnd = res.end.bind(res);
  (res as any).end = function (...args: any[]) {
    const log: GatewayLog = {
      id:          uuidv4(),
      method:      req.method,
      path:        req.path,
      status_code: res.statusCode,
      duration_ms: Date.now() - start,
      client_ip:   getClientIP(req),
      api_key:     (req.headers["x-api-key"] as string)?.slice(0, 12) + "..." || null,
      owner:       !!(req.headers["x-owner-token"]),
      user_agent:  (req.headers["user-agent"] || "").slice(0, 80),
      timestamp:   new Date().toISOString(),
      error:       res.statusCode >= 500 ? "server_error" : null,
      bytes_sent:  args[0] ? Buffer.byteLength(String(args[0])) : 0,
    };
    gatewayLogs.push(log);
    if (gatewayLogs.length > MAX_GATEWAY_LOGS) gatewayLogs.shift();
    if (res.statusCode >= 500) {
      monitoringBus.emit("gateway:error", log);
    }
    return origEnd(...args);
  };
  next();
}

function getGatewayStats(lastN = 200): any {
  const recent = gatewayLogs.slice(-lastN);
  const durations = recent.map(g => g.duration_ms);
  const avg_ms    = durations.length ? +(durations.reduce((a,b)=>a+b,0)/durations.length).toFixed(1) : 0;
  const p95_ms    = durations.length ? +([...durations].sort((a,b)=>a-b)[Math.floor(durations.length*0.95)]||0).toFixed(1) : 0;
  const by_status: Record<string,number> = {};
  for (const g of recent) {
    const code = String(Math.floor(g.status_code/100)+"xx");
    by_status[code] = (by_status[code]||0)+1;
  }
  const top_paths: Record<string,number> = {};
  for (const g of recent) top_paths[g.path] = (top_paths[g.path]||0)+1;
  return {
    window:     lastN,
    total_requests: recent.length,
    avg_latency_ms: avg_ms,
    p95_latency_ms: p95_ms,
    error_rate: recent.length ? +((recent.filter(g=>g.status_code>=500).length/recent.length)*100).toFixed(1) : 0,
    by_status,
    top_paths: Object.entries(top_paths).sort((a,b)=>b[1]-a[1]).slice(0,10),
    unique_ips: new Set(recent.map(g=>g.client_ip)).size,
  };
}

