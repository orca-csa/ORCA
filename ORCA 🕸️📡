// L1 Port Scanner
function scanPort(host: string, port: number, ms = 1500): Promise<any> {
  return new Promise(resolve => {
    const s = new net.Socket(); const r = { port, state:"closed", service:SERVICE_DB[port]||"unknown", risk:RISK_PORTS[port]||"LOW", latency:0 };
    s.setTimeout(ms);
    s.connect(port, host, () => { r.state="open"; r.latency=Date.now(); s.destroy(); resolve(r); });
    s.on("timeout", () => { r.state="filtered"; s.destroy(); resolve(r); });
    s.on("error",   (e:any) => { r.state=e.code==="ECONNREFUSED"?"closed":"filtered"; s.destroy(); resolve(r); });
  });
}

async function scanHost(host: string, ports = COMMON_PORTS, ms = 1500): Promise<any> {
  let ip = host; try { ip = (await dns.lookup(host)).address; } catch {}
  const BATCH=50; const open:any[]=[];let closed=0,filtered=0;
  for(let i=0;i<ports.length;i+=BATCH){const rs=await Promise.all(ports.slice(i,i+BATCH).map(p=>scanPort(ip,p,ms)));for(const r of rs){if(r.state==="open")open.push(r);else if(r.state==="filtered")filtered++;else closed++;}}
  open.sort((a,b)=>a.port-b.port);
  const risk={CRITICAL:0,HIGH:0,MEDIUM:0,LOW:0}as any;for(const p of open)risk[p.risk]++;
  return{target:host,ip,scan_time:new Date().toISOString(),ports_scanned:ports.length,open_ports:open,open_count:open.length,closed_count:closed,filtered_count:filtered,risk_summary:risk};
}

