// GET all roles (owner only)
app.get("/api/rbac/roles", requirePermission("role:manage"), (_req, res) => {
  res.json({
    definitions: Object.entries(ROLE_PERMISSIONS).map(([role, perms]) => ({
      role,
      permissions_count: perms.length,
      permissions: perms,
    })),
    assigned: Array.from(roleStoreV5.values()),
    total_assigned: roleStoreV5.size,
  });
});

// POST grant role
app.post("/api/rbac/grant", requirePermission("role:manage"), (req, res) => {
  const { email, role, expires_in_days, reason } = req.body;
  if (!email || !role) return res.status(400).json({ error: "email and role required" });
  if (!ROLE_PERMISSIONS[role as RoleName]) return res.status(400).json({ error: `Invalid role. Valid: ${Object.keys(ROLE_PERMISSIONS).join(", ")}` });
  if (isOwner(email)) return res.status(400).json({ error: "Cannot override owner permissions" });
  const expiresAt = expires_in_days ? Date.now() + expires_in_days * 86400_000 : undefined;
  const record    = grantRole(email, role as RoleName, (req as any).authEmail, expiresAt, reason);
  res.json({ success: true, record });
});

// DELETE revoke role
app.delete("/api/rbac/revoke/:email", requirePermission("role:manage"), (req, res) => {
  const revoked = revokeRole(req.params.email, (req as any).authEmail);
  revoked ? res.json({ success: true }) : res.status(404).json({ error: "No custom role found" });
});

// GET check permission
app.get("/api/rbac/check", (req, res) => {
  const token = req.headers["x-owner-token"] as string;
  const email = verifySession(token);
  if (!email) return res.status(401).json({ error: "Authentication required" });
  const { permission } = req.query as { permission: Permission };
  res.json({
    email,
    role:       getRole(email),
    permission: permission || "n/a",
    allowed:    permission ? hasPermission(email, permission) : null,
    all_permissions: ROLE_PERMISSIONS[getRole(email)] || [],
  });
});

