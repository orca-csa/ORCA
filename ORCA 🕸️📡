// ── 1. ASSET MANAGEMENT ─────────────────────────────────────────
interface Asset {
  id: string; email: string; label: string; target: string;
  type: "domain" | "ip" | "url"; created_at: string; last_scan: string | null;
}
const assetStore    = new Map<string, Asset>();
const assetsByEmail = new Map<string, Set<string>>();

function addAsset(email: string, label: string, target: string): Asset {
  const type: Asset["type"] = target.startsWith("http") ? "url"
    : /^(\d{1,3}\.){3}\d{1,3}$/.test(target) ? "ip" : "domain";
  const asset: Asset = { id: uuidv4(), email: email.toLowerCase(), label, target, type, created_at: new Date().toISOString(), last_scan: null };
  assetStore.set(asset.id, asset);
  if (!assetsByEmail.has(email)) assetsByEmail.set(email, new Set());
  assetsByEmail.get(email)!.add(asset.id);
  return asset;
}
function getAssets(email: string): Asset[] {
  return Array.from(assetsByEmail.get(email.toLowerCase()) || new Set()).map(id => assetStore.get(id)!).filter(Boolean);
}
function deleteAsset(email: string, assetId: string): boolean {
  const asset = assetStore.get(assetId);
  if (!asset || asset.email !== email.toLowerCase()) return false;
  assetStore.delete(assetId); assetsByEmail.get(email)?.delete(assetId); return true;
}

// ── 2. SCAN HISTORY ─────────────────────────────────────────────
interface ScanRecord {
  id: string; email: string; asset_id: string | null; target: string;
  scan_type: "port_scan" | "dns_recon" | "vuln_scan" | "ioc_external";
  result: any; summary: any; created_at: string;
}
const scanHistoryStore  = new Map<string, ScanRecord>();
const scansByEmailStore = new Map<string, string[]>();

function buildScanSummary(scan_type: string, result: any): any {
  if (scan_type === "port_scan")    return { open_ports: result?.open_count || 0, risk: result?.risk_summary || {} };
  if (scan_type === "dns_recon")    return { subdomains: result?.found_subdomains || 0, records: Object.keys(result?.records || {}) };
  if (scan_type === "vuln_scan")    return { findings: result?.findings_count || 0, summary: result?.summary || {} };
  if (scan_type === "ioc_external") return { abuse_score: result?.abuseipdb?.abuse_score || 0, vt_malicious: result?.virustotal?.malicious_count || 0, severity: result?.abuseipdb?.severity || result?.virustotal?.severity || "LOW" };
  return {};
}

function saveScanResult(email: string, target: string, scan_type: ScanRecord["scan_type"], result: any, asset_id: string | null = null): ScanRecord {
  const record: ScanRecord = { id: uuidv4(), email: email.toLowerCase(), asset_id, target, scan_type, result, summary: buildScanSummary(scan_type, result), created_at: new Date().toISOString() };
  scanHistoryStore.set(record.id, record);
  if (!scansByEmailStore.has(email)) scansByEmailStore.set(email, []);
  scansByEmailStore.get(email)!.push(record.id);
  const ids = scansByEmailStore.get(email)!;
  if (ids.length > 200) { const removed = ids.splice(0, ids.length - 200); removed.forEach(id => scanHistoryStore.delete(id)); }
  if (asset_id) { const a = assetStore.get(asset_id); if (a) a.last_scan = record.created_at; }
  return record;
}

function getScanHistory(email: string, limit = 50): ScanRecord[] {
  return (scansByEmailStore.get(email.toLowerCase()) || []).slice(-limit).reverse().map(id => scanHistoryStore.get(id)!).filter(Boolean);
}

function diffScans(email: string, target: string, scan_type: ScanRecord["scan_type"]): any {
  const all = getScanHistory(email, 200).filter(r => r.target === target && r.scan_type === scan_type);
  if (all.length < 2) return { message: "Need at least 2 scans to compare", scans: all.length };
  const latest = all[0], prev = all[1];
  const diff: any = { target, scan_type, compared_at: new Date().toISOString() };
  if (scan_type === "port_scan") {
    const lp = new Set((latest.result?.open_ports || []).map((p: any) => p.port));
    const pp = new Set((prev.result?.open_ports   || []).map((p: any) => p.port));
    diff.new_open_ports = [...lp].filter(p => !pp.has(p));
    diff.closed_ports   = [...pp].filter(p => !lp.has(p));
    diff.unchanged      = [...lp].filter(p => pp.has(p));
  }
  if (scan_type === "vuln_scan") {
    const lf = new Set((latest.result?.findings || []).map((f: any) => f.title));
    const pf = new Set((prev.result?.findings   || []).map((f: any) => f.title));
    diff.new_findings = [...lf].filter(f => !pf.has(f));
    diff.resolved     = [...pf].filter(f => !lf.has(f));
    diff.unchanged    = [...lf].filter(f => pf.has(f));
  }
  diff.previous_scan = { id: prev.id, date: prev.created_at, summary: prev.summary };
  diff.latest_scan   = { id: latest.id, date: latest.created_at, summary: latest.summary };
  return diff;
}

// ── 3. SCHEDULED SCANS ──────────────────────────────────────────
interface ScheduledScan {
  id: string; email: string; asset_id: string; scan_type: ScanRecord["scan_type"];
  schedule: "daily" | "weekly" | "monthly"; cron_expr: string;
  active: boolean; last_run: string | null; next_run: string | null; created_at: string;
}
const scheduleStore = new Map<string, ScheduledScan>();
const cronJobs      = new Map<string, any>();
const CRON_EXPRS    = { daily: "0 3 * * *", weekly: "0 3 * * 1", monthly: "0 3 1 * *" };

function createSchedule(email: string, asset_id: string, scan_type: ScheduledScan["scan_type"], schedule: "daily"|"weekly"|"monthly"): ScheduledScan {
  const id = uuidv4();
  const cronExpr = CRON_EXPRS[schedule];
  const sched: ScheduledScan = { id, email: email.toLowerCase(), asset_id, scan_type, schedule, cron_expr: cronExpr, active: true, last_run: null, next_run: new Date(Date.now() + 86400000).toISOString(), created_at: new Date().toISOString() };
  scheduleStore.set(id, sched);
  const task = cron.schedule(cronExpr, async () => {
    const asset = assetStore.get(asset_id);
    if (!asset || !sched.active) return;
    sched.last_run = new Date().toISOString();
    sched.next_run = new Date(Date.now() + 86400000).toISOString();
    try {
      let result: any;
      if (scan_type === "port_scan")    result = await scanHost(asset.target, COMMON_PORTS, 1500);
      else if (scan_type === "dns_recon") result = await dnsRecon(asset.target);
      else if (scan_type === "vuln_scan") result = await nucleiScan(asset.target);
      else if (scan_type === "ioc_external") result = await lookupIOCExternal(asset.target);
      if (result) {
        const record = saveScanResult(email, asset.target, scan_type, result, asset_id);
        await triggerAlerts(email, asset.target, scan_type, result, record.id);
      }
    } catch (e) { console.error(`[SCHEDULE] Failed: ${asset.target}`, e); }
  });
  cronJobs.set(id, task);
  return sched;
}

function deleteSchedule(email: string, scheduleId: string): boolean {
  const sched = scheduleStore.get(scheduleId);
  if (!sched || sched.email !== email.toLowerCase()) return false;
  cronJobs.get(scheduleId)?.destroy(); cronJobs.delete(scheduleId); scheduleStore.delete(scheduleId); return true;
}
function getSchedules(email: string): ScheduledScan[] {
  return Array.from(scheduleStore.values()).filter(s => s.email === email.toLowerCase());
}

