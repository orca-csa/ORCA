import * as pathMod from "path";

const UPLOAD_DIR    = pathMod.join(process.cwd(), "orca_uploads");
const MAX_FILE_SIZE = 10 * 1024 * 1024; // 10 MB
const ALLOWED_EXTS  = new Set([
  ".txt", ".csv", ".json", ".js", ".ts", ".py", ".sql",
  ".sh", ".html", ".xml", ".log", ".md", ".yaml", ".yml",
]);

interface UploadedFile {
  id:          string;
  name:        string;
  ext:         string;
  mime_type:   string;
  size:        number;
  filepath:    string;
  owner_email: string;
  processed:   boolean;
  analysis:    any | null;
  checksum:    string;
  task_id:     string | null;
  uploaded_at: string;
  tags:        string[];
}

const fileStore = new Map<string, UploadedFile>();

// Create upload directory safely
try { fs.mkdirSync(UPLOAD_DIR, { recursive: true }); } catch {}

// ── Multipart Parser ──────────────────────────────────────────
function parseMultipart(
  req: Request
): Promise<{ fields: Record<string, string>; files: Array<{ name: string; mime: string; data: Buffer }> }> {
  return new Promise((resolve, reject) => {
    const ct = req.headers["content-type"] || "";
    if (!ct.includes("multipart/form-data")) return resolve({ fields: {}, files: [] });

    const boundary = ct.split("boundary=")[1];
    if (!boundary) return reject(new Error("No multipart boundary found"));

    const chunks: Buffer[] = [];
    req.on("data",  c => chunks.push(c));
    req.on("error", reject);
    req.on("end",  () => {
      try {
        const body  = Buffer.concat(chunks);
        const delim = `--${boundary}`;
        const parts = body.toString("binary").split(delim).slice(1, -1);
        const fields: Record<string, string> = {};
        const files:  Array<{ name: string; mime: string; data: Buffer }> = [];

        for (const part of parts) {
          const sep        = part.indexOf("\r\n\r\n");
          if (sep === -1)  continue;
          const headerRaw  = part.slice(0, sep);
          const bodyRaw    = part.slice(sep + 4).replace(/\r\n$/, "");
          const headers    = headerRaw.split("\r\n").slice(1);
          const dispLine   = headers.find(h => h.toLowerCase().startsWith("content-disposition")) || "";
          const ctLine     = headers.find(h => h.toLowerCase().startsWith("content-type"))        || "";
          const nameMatch  = dispLine.match(/name="([^"]+)"/);
          const fileMatch  = dispLine.match(/filename="([^"]+)"/);
          const mime       = ctLine.split(": ")[1]?.trim() || "application/octet-stream";
          const fieldName  = nameMatch?.[1] || "";
          const fileName   = fileMatch?.[1] || "";

          if (fileName) {
            files.push({ name: fileName, mime, data: Buffer.from(bodyRaw, "binary") });
          } else if (fieldName) {
            fields[fieldName] = bodyRaw;
          }
        }
        resolve({ fields, files });
      } catch (e) { reject(e); }
    });
  });
}

// ── File Save ─────────────────────────────────────────────────
async function saveUploadedFile(
  file:       { name: string; mime: string; data: Buffer },
  ownerEmail: string,
  tags:       string[] = []
): Promise<UploadedFile | { error: string }> {
  const ext = pathMod.extname(file.name).toLowerCase();

  if (!ALLOWED_EXTS.has(ext))
    return { error: `File type not allowed: ${ext}. Allowed: ${Array.from(ALLOWED_EXTS).join(", ")}` };
  if (file.data.length > MAX_FILE_SIZE)
    return { error: `File too large. Max: ${MAX_FILE_SIZE / 1024 / 1024} MB` };

  const id       = uuidv4();
  const savePath = pathMod.join(UPLOAD_DIR, `${id}${ext}`);
  const checksum = crypto.createHash("sha256").update(file.data).digest("hex");

  // Duplicate detection
  for (const existing of fileStore.values()) {
    if (existing.checksum === checksum && existing.owner_email === ownerEmail.toLowerCase()) {
      return { error: `Duplicate file detected. Already uploaded as: ${existing.name} (id: ${existing.id})` };
    }
  }

  fs.writeFileSync(savePath, file.data);

  const record: UploadedFile = {
    id, name: file.name, ext, mime_type: file.mime,
    size:        file.data.length,
    filepath:    savePath,
    owner_email: ownerEmail.toLowerCase(),
    processed:   false,
    analysis:    null,
    checksum,
    task_id:     null,
    uploaded_at: new Date().toISOString(),
    tags,
  };
  fileStore.set(id, record);

  // Auto-queue code analysis for source code files
  if ([".js", ".ts", ".py", ".sql", ".sh"].includes(ext)) {
    const task       = enqueueTask(
      "code_analyze",
      { file_id: id, content: file.data.toString("utf-8"), file_name: file.name },
      { priority: "normal", tags: ["auto", "file_upload"] }
    );
    record.task_id = task.id;
  }

  activityTracker.record(ownerEmail, "file:uploaded", { name: file.name, size: file.data.length, ext });
  orcaDB.markDirty();
  return record;
}

function deleteFile(id: string, email: string): { success: boolean; error?: string } {
  const file = fileStore.get(id);
  if (!file) return { success: false, error: "File not found" };
  if (file.owner_email !== email.toLowerCase() && !isOwner(email))
    return { success: false, error: "Not authorized to delete this file" };
  try { if (fs.existsSync(file.filepath)) fs.unlinkSync(file.filepath); } catch {}
  fileStore.delete(id);
  activityTracker.record(email, "file:deleted", { name: file.name });
  return { success: true };
}

function getFileContent(id: string): Buffer | null {
  const file = fileStore.get(id);
  if (!file) return null;
  try { return fs.readFileSync(file.filepath); } catch { return null; }
}

