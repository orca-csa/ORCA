function analyzePackets(packets:any[]):any[]{
  const alerts2:any[]=[];const ports=new Map<string,Set<number>>();const conns=new Map<string,number>();
  for(const p of packets){
    const k=`${p.src_ip}->${p.dst_ip}`;if(!ports.has(k))ports.set(k,new Set());ports.get(k)!.add(p.dst_port);
    if(ports.get(k)!.size>15){alerts2.push(makeAlert("HIGH","Recon","PORT_SCAN",p.src_ip,p.dst_ip,`${ports.get(k)!.size} ports`));ports.get(k)!.clear();}
    if([22,21,3389].includes(p.dst_port)){conns.set(k,(conns.get(k)||0)+1);if(conns.get(k)!>10){alerts2.push(makeAlert("HIGH","BruteForce","BRUTE_FORCE",p.src_ip,p.dst_ip,`${conns.get(k)} attempts`));conns.set(k,0);}}
    if(p.payload&&/union\s+select|or\s+1=1|drop\s+table/i.test(p.payload))alerts2.push(makeAlert("CRITICAL","WebAttack","SQL_INJECTION",p.src_ip,p.dst_ip,"SQLi"));
    if(p.payload?.includes("BEACON"))alerts2.push(makeAlert("CRITICAL","Malware","C2_BEACON",p.src_ip,p.dst_ip,"C2 beacon"));
    if(p.protocol==="UDP"&&p.dst_port===53&&p.size>150)alerts2.push(makeAlert("HIGH","Exfil","DNS_TUNNEL",p.src_ip,p.dst_ip,`${p.size}b DNS`));
  }
  return alerts2;
}

