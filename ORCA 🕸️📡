interface CLICommand {
  name:        string;
  description: string;
  usage:       string;
  handler:     (args: Record<string,string>, raw: string[]) => Promise<string> | string;
}

const cliRegistry = new Map<string, CLICommand>();

function registerCLI(cmd: CLICommand): void { cliRegistry.set(cmd.name, cmd); }

function parseCLIArgs(parts: string[]): Record<string,string> {
  const args: Record<string,string> = {};
  for (let i = 0; i < parts.length; i++) {
    if (parts[i].startsWith("--")) {
      const key = parts[i].slice(2);
      args[key] = parts[i+1] && !parts[i+1].startsWith("--") ? (i++, parts[i]) : "true";
    } else {
      args[`_${i}`] = parts[i];
    }
  }
  return args;
}

async function executeCLI(input: string, callerEmail = "anonymous"): Promise<string> {
  const parts   = input.trim().split(/\s+/);
  const name    = parts[0]?.toLowerCase();
  if (!name)    return "Enter a command. Type 'help' for list.";
  const cmd     = cliRegistry.get(name);
  if (!cmd)     return `Unknown command: '${name}'\nType 'help' to see available commands.`;
  activityTracker.record(callerEmail, "cli:execute", { command: name });
  try { return await cmd.handler(parseCLIArgs(parts.slice(1)), parts.slice(1)); }
  catch(e) { return `[ERROR] ${String(e)}`; }
}

