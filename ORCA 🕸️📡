// L1 NMAP ADVANCED SCANNER — OS fingerprinting + Service versions + Banners
// Requires: nmap installed on the server (apt install nmap)
// ════════════════════════════════════════════════════════════════

function sanitizeShellTarget(target: string): string {
  // Allow only safe characters: alphanumeric, dots, hyphens, underscores, colons (for IPv6), brackets (for IPv6)
  const sanitized = target.replace(/[^a-zA-Z0-9.\-_:\[\]\/]/g, "");
  if (sanitized !== target) throw new Error("Invalid characters in target address");
  if (sanitized.length > 253) throw new Error("Target address too long");
  return sanitized;
}

function runNmap(target: string, args: string): Promise<string> {
  const safeTarget = sanitizeShellTarget(target);
  // Use spawn instead of exec to prevent shell injection
  return new Promise((resolve, reject) => {
    const { spawn } = require("child_process");
    const argList = args.split(" ").concat([safeTarget]);
    const proc = spawn("nmap", argList, { timeout: 60000 });
    let stdout = "", stderr = "";
    proc.stdout.on("data", (d: Buffer) => { stdout += d.toString(); });
    proc.stderr.on("data", (d: Buffer) => { stderr += d.toString(); });
    proc.on("close", (code: number) => {
      if (code !== 0 && !stdout) reject(new Error(stderr || `nmap exited with code ${code}`));
      else resolve(stdout || "");
    });
    proc.on("error", (err: Error) => reject(err));
  });
}

function parseNmapXml(raw: string): any {
  const openPorts: any[] = [];
  const portRe   = /<port protocol="(\w+)" portid="(\d+)">([\s\S]*?)<\/port>/g;
  const serviceRe= /<service name="([^"]*)"(?:[^>]*product="([^"]*)")?(?:[^>]*version="([^"]*)")?(?:[^>]*extrainfo="([^"]*)")?/;
  const bannerRe = /<script id="banner" output="([^"]*)"/;
  const stateRe  = /<state state="([^"]*)"[^/]*\/>/;
  let m;
  while ((m = portRe.exec(raw)) !== null) {
    const [, proto, portStr, block] = m;
    const stateM   = block.match(stateRe);
    if (!stateM || stateM[1] !== "open") continue;
    const svcM     = block.match(serviceRe);
    const bannerM  = block.match(bannerRe);
    const port     = parseInt(portStr);
    openPorts.push({
      port, protocol: proto, state: "open",
      service:  svcM?.[1] || SERVICE_DB[port] || "unknown",
      product:  svcM?.[2] || "",
      version:  svcM?.[3] || "",
      extrainfo:svcM?.[4] || "",
      banner:   bannerM?.[1] || "",
      risk:     RISK_PORTS[port] || "LOW",
    });
  }
  const osRe = /<osmatch name="([^"]*)" accuracy="(\d+)"/;
  const osM  = raw.match(osRe);
  return {
    open_ports: openPorts,
    os_match:   osM ? { name: osM[1], accuracy: parseInt(osM[2]) } : null,
  };
}

async function nmapScan(target: string, portRange = "1-65535"): Promise<any> {
  const start = Date.now();
  // -sV = service version, -O = OS detect, --script=banner = banner grab, -T4 = fast timing, -oX - = XML output
  const args = `-sV -O -T4 --script=banner -p ${portRange} -oX -`;
  let raw = "";
  try {
    raw = await runNmap(target, args);
  } catch (e) {
    // Fallback: try without -O (requires root) 
    try { raw = await runNmap(target, `-sV -T4 --script=banner -p ${portRange} -oX -`); }
    catch { return { error: "Nmap not available. Install with: apt install nmap", fallback: true, ...(await scanHost(target, COMMON_PORTS, 1500)) }; }
  }
  const parsed = parseNmapXml(raw);
  const risk   = { CRITICAL: 0, HIGH: 0, MEDIUM: 0, LOW: 0 } as any;
  for (const p of parsed.open_ports) risk[p.risk] = (risk[p.risk] || 0) + 1;
  return {
    target,
    scan_type:     "nmap_advanced",
    scan_time:     new Date().toISOString(),
    duration_ms:   Date.now() - start,
    os_fingerprint: parsed.os_match,
    open_ports:    parsed.open_ports,
    open_count:    parsed.open_ports.length,
    risk_summary:  risk,
    raw_xml:       raw.slice(0, 20000), // cap size
  };
}

async function dnsRecon(domain: string): Promise<any> {
  const records:any={};
  const safe=async(t:string,fn:()=>Promise<any>)=>{try{const r=await fn();records[t]=Array.isArray(r)?r.map((x:any)=>typeof x==="string"?x:JSON.stringify(x)):[]}catch{}};
  await safe("A",()=>dns.resolve4(domain));await safe("AAAA",()=>dns.resolve6(domain));
  await safe("MX",()=>dns.resolveMx(domain).then((r:any[])=>r.map(x=>`${x.priority} ${x.exchange}`)));
  await safe("NS",()=>dns.resolveNs(domain));await safe("TXT",()=>dns.resolveTxt(domain).then((r:any[])=>r.map(x=>x.join(""))));
  const subs:any[]=[];
  await Promise.all(["www","mail","ftp","api","dev","admin","vpn","app"].map(async s=>{try{const a=await dns.lookup(`${s}.${domain}`);subs.push({subdomain:`${s}.${domain}`,ip:a.address});}catch{}}));
  return{domain,records,subdomains:subs,found_subdomains:subs.length,scan_time:new Date().toISOString()};
}

