interface ActivityEvent {
  id:        string;
  actor:     string;
  action:    string;
  resource:  string;
  data:      any;
  ip:        string | null;
  timestamp: string;
}

const activityLog: ActivityEvent[] = [];
const MAX_ACTIVITY = 5000;

const activityTracker = {
  record(actor: string, action: string, data: any = {}, ip: string | null = null): void {
    const event: ActivityEvent = {
      id:        uuidv4(),
      actor:     actor || "system",
      action,
      resource:  action.split(":")[0] || "unknown",
      data,
      ip,
      timestamp: new Date().toISOString(),
    };
    activityLog.push(event);
    if (activityLog.length > MAX_ACTIVITY) activityLog.shift();
  },
  get(actor?: string, resource?: string, limit = 50): ActivityEvent[] {
    let events = activityLog.slice(-Math.min(limit * 4, MAX_ACTIVITY));
    if (actor)    events = events.filter(e => e.actor === actor);
    if (resource) events = events.filter(e => e.resource === resource);
    return events.slice(-limit).reverse();
  },
};

