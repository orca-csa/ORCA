    `Scan ID   : ${scan.id}`,
    `Date      : ${scan.created_at}`,
    `Generated : ${new Date().toISOString()}`,
    "───────────────────────────────────────────",
    "SUMMARY",
    "───────────────────────────────────────────",
    ...Object.entries(scan.summary||{}).map(([k,v])=>`  ${k.padEnd(16)}: ${v}`),
    "───────────────────────────────────────────",
    "FINDINGS",
    "───────────────────────────────────────────",
  ];
  const findings = extractFindings(scan.scan_type, scan.result);
  if (!findings.length) {
    lines.push("  No critical or high findings.");
  } else {
    for (const f of findings) {
      lines.push(`  [${f.severity}] ${f.title}`);
      if (f.detail)      lines.push(`    Detail      : ${f.detail}`);
      if (f.remediation) lines.push(`    Remediation : ${f.remediation}`);
      lines.push("");
    }
  }
  lines.push("═══════════════════════════════════════════");
  lines.push("  ORCA Security Platform v5.0.0 — Confidential");
  return lines.join("\n");
}

