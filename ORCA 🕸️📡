// Agent runtime state
const agentRegistry = new Map<string, any>();
const runningTasks  = new Set<string>(); // Deduplication set

function initAgents() {
  for (const def of AGENT_DEFINITIONS) {
    agentRegistry.set(def.id, {
      ...def,
      status:      def.needs_ai && !aiReady() ? "WAITING_FOR_API_KEY" : "IDLE",
      runs:        0,
      last_run:    "",
      last_output: "",
      errors:      0,
    });
  }
}
initAgents();

function updateAgent(id: string, status: string, output: string) {
  const a = agentRegistry.get(id);
  if (!a) return;
  a.status      = status;
  a.last_run    = new Date().toISOString();
  a.last_output = output.slice(0, 300);
  a.runs++;
}

// Task deduplication
function canRun(agentId: string, taskKey: string): boolean {
  const key = `${agentId}:${taskKey}`;
  if (runningTasks.has(key)) return false;
  runningTasks.add(key);
  setTimeout(() => runningTasks.delete(key), 60000); // Auto-release after 1 min
  return true;
}

// ════════════════════════════════════════════════════════════════
// AG-101 SUPERVISOR — No AI needed, always running
// ════════════════════════════════════════════════════════════════

function runSupervisor(): any {
  const agents  = Array.from(agentRegistry.values());
  const stopped = agents.filter(a => a.status === "IDLE" && a.runs === 0 && !a.needs_ai);
  const waiting = agents.filter(a => a.status === "WAITING_FOR_API_KEY");
  const running = agents.filter(a => a.status === "RUNNING");
  const alerts: string[] = [];

  if (!aiReady())   alerts.push(`⚠ ${waiting.length} agents waiting for API key`);
  if (!kingReady()) alerts.push("⚠ ORCA KING waiting for ANTHROPIC_API_KEY");
  if (pendingQueue.length > 100) alerts.push(`⚠ Task queue has ${pendingQueue.length} items`);

  // Update all waiting agents status if AI became ready
  if (aiReady()) {
    for (const a of waiting) {
      if (a.needs_ai) a.status = "IDLE";
    }
  }

  updateAgent("AG-101", "IDLE", `Supervised: ${agents.length} agents | Running: ${running.length} | Waiting: ${waiting.length}`);
  updateAgent("AG-100", "IDLE", `Coordinating ${agents.length} agents | Active tasks: ${runningTasks.size}`);

  return { timestamp: new Date().toISOString(), total: agents.length, running: running.length, waiting: waiting.length, alerts, uptime_ms: Date.now() - startTime };
}

setInterval(() => {
  const r = runSupervisor();
  if (r.alerts.length) console.warn("[AG-101 SUPERVISOR]", r.alerts.join(" | "));
}, 5 * 60 * 1000);

