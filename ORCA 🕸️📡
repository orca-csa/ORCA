interface Worker {
  id:           string;
  name:         string;
  status:       "idle" | "busy" | "stopped" | "error";
  current_task: string | null;
  tasks_done:   number;
  errors:       number;
  started_at:   string;
  last_active:  string | null;
  last_error:   string | null;
  concurrency:  number; // tasks this worker can handle
}

const workerPool  = new Map<string, Worker>();
const WORKER_COUNT = 4;

function createWorker(name: string, concurrency = 1): Worker {
  const worker: Worker = {
    id:           uuidv4(),
    name,
    status:       "idle",
    current_task: null,
    tasks_done:   0,
    errors:       0,
    started_at:   new Date().toISOString(),
    last_active:  null,
    last_error:   null,
    concurrency,
  };
  workerPool.set(worker.id, worker);
  return worker;
}

function stopWorker(id: string): boolean {
  const w = workerPool.get(id);
  if (!w || w.status === "busy") return false;
  w.status = "stopped"; return true;
}

function restartWorker(id: string): boolean {
  const w = workerPool.get(id);
  if (!w) return false;
  w.status = "idle"; w.last_error = null; return true;
}

function getWorkerStats(): any {
  const workers = Array.from(workerPool.values());
  return {
    total:     workers.length,
    idle:      workers.filter(w=>w.status==="idle").length,
    busy:      workers.filter(w=>w.status==="busy").length,
    stopped:   workers.filter(w=>w.status==="stopped").length,
    error:     workers.filter(w=>w.status==="error").length,
    total_tasks_processed: workers.reduce((a,w)=>a+w.tasks_done,0),
    total_errors:          workers.reduce((a,w)=>a+w.errors,0),
    workers: workers.map(w=>({
      id:w.id, name:w.name, status:w.status,
      tasks_done:w.tasks_done, errors:w.errors,
      current_task:w.current_task, last_active:w.last_active,
    })),
  };
}

// Initialize worker pool
for (let i = 0; i < WORKER_COUNT; i++) {
  createWorker(`Worker-${i + 1}`);
}
// One high-concurrency worker for quick tasks
createWorker("Worker-Fast", 2);

// ── Worker Dispatch Loop — every 300ms ──────────────────────
setInterval(async () => {
  const idleWorkers = Array.from(workerPool.values()).filter(w => w.status === "idle");
  for (const worker of idleWorkers) {
    const task = getNextTask();
    if (!task) break;

    worker.status       = "busy";
    worker.current_task = task.id;
    worker.last_active  = new Date().toISOString();

    processTask(task).then(() => {
      worker.tasks_done++;
      worker.last_active  = new Date().toISOString();
      worker.current_task = null;
      worker.status       = "idle";
      if (task.status === "failed") worker.errors++;
    }).catch((e) => {
      worker.errors++;
      worker.last_error   = String(e);
      worker.status       = "idle";
      worker.current_task = null;
      monitoringBus.emit("worker:error", { worker_id: worker.id, error: String(e) });
    });
  }
}, 300);

