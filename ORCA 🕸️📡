interface ServiceApiKey {
  id:          string;
  key:         string;
  key_hash:    string;  // stored hashed — only show once
  name:        string;
  scope:       string[];
  owner_email: string;
  active:      boolean;
  last_used:   string | null;
  use_count:   number;
  created_at:  string;
  expires_at:  string | null;
  ip_whitelist:string[];
}

const serviceKeyStore = new Map<string, ServiceApiKey>(); // key_hash → record
const keyIdIndex      = new Map<string, string>();         // id → key_hash

function generateServiceApiKey(
  name: string,
  scope: string[],
  ownerEmail: string,
  expiresInDays?: number,
  ipWhitelist: string[] = []
): { record: ServiceApiKey; raw_key: string } {
  const rawKey = `orca_sk_${crypto.randomBytes(28).toString("hex")}`;
  const hash   = crypto.createHash("sha256").update(rawKey).digest("hex");
  const record: ServiceApiKey = {
    id:          uuidv4(),
    key:         rawKey.slice(0, 12) + "..." + rawKey.slice(-4), // masked
    key_hash:    hash,
    name,
    scope,
    owner_email: ownerEmail.toLowerCase(),
    active:      true,
    last_used:   null,
    use_count:   0,
    created_at:  new Date().toISOString(),
    expires_at:  expiresInDays ? new Date(Date.now() + expiresInDays * 86400_000).toISOString() : null,
    ip_whitelist: ipWhitelist,
  };
  serviceKeyStore.set(hash, record);
  keyIdIndex.set(record.id, hash);
  activityTracker.record(ownerEmail, "apikey:created", { name, scope });
  return { record, raw_key: rawKey }; // raw_key shown once
}

function validateServiceKey(rawKey: string, ip?: string): ServiceApiKey | null {
  const hash   = crypto.createHash("sha256").update(rawKey).digest("hex");
  const record = serviceKeyStore.get(hash);
  if (!record || !record.active) return null;
  if (record.expires_at && Date.now() > new Date(record.expires_at).getTime()) {
    record.active = false; return null;
  }
  if (record.ip_whitelist.length > 0 && ip && !record.ip_whitelist.includes(ip)) return null;
  record.last_used = new Date().toISOString();
  record.use_count++;
  return record;
}

function revokeServiceKey(id: string, revokedBy: string): boolean {
  const hash   = keyIdIndex.get(id);
  if (!hash) return false;
  const record = serviceKeyStore.get(hash);
  if (!record) return false;
  record.active = false;
  activityTracker.record(revokedBy, "apikey:revoked", { name: record.name });
  return true;
}

