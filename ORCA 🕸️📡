type NotificationType =
  | "alert" | "scan_complete" | "subscription_expired" | "incident_created"
  | "sla_breach" | "system" | "security" | "report_ready" | "worker_error" | "api_key_expiring";

interface Notification {
  id:         string;
  type:       NotificationType;
  recipient:  string;
  title:      string;
  body:       string;
  data:       any;
  read:       boolean;
  priority:   "high" | "normal" | "low";
  channels:   string[];
  sent_at:    string;
  expires_at: string | null;
}

const notificationStore = new Map<string, Notification[]>(); // email → notifications
const MAX_NOTIFS_PER_USER = 100;

const NOTIF_TITLES: Record<NotificationType, string> = {
  alert:               "🚨 Security Alert",
  scan_complete:       "✅ Scan Completed",
  subscription_expired:"⚠️ Subscription Expired",
  incident_created:    "🔴 New Incident Created",
  sla_breach:          "❌ SLA Deadline Breached",
  system:              "ℹ️ System Notice",
  security:            "🔒 Security Notice",
  report_ready:        "📄 Report Ready",
  worker_error:        "⚙️ Worker Error",
  api_key_expiring:    "🔑 API Key Expiring Soon",
};

function createNotification(
  email:    string,
  type:     NotificationType,
  data:     any = {},
  priority: Notification["priority"] = "normal",
  ttlMs?:   number
): Notification {
  const notif: Notification = {
    id:         uuidv4(),
    type,
    recipient:  email.toLowerCase(),
    title:      NOTIF_TITLES[type] || type,
    body:       typeof data === "string" ? data : JSON.stringify(data).slice(0, 500),
    data,
    read:       false,
    priority,
    channels:   ["in-app"],
    sent_at:    new Date().toISOString(),
    expires_at: ttlMs ? new Date(Date.now() + ttlMs).toISOString() : null,
  };

  if (!notificationStore.has(email.toLowerCase()))
    notificationStore.set(email.toLowerCase(), []);

  const userNotifs = notificationStore.get(email.toLowerCase())!;
  userNotifs.unshift(notif);
  if (userNotifs.length > MAX_NOTIFS_PER_USER) userNotifs.pop();

  orcaLog("DEBUG", "notification", `${type} → ${email}`, { priority });
  return notif;
}

// Cleanup expired notifications every hour
setInterval(() => {
  const now = new Date().toISOString();
  for (const [, notifs] of notificationStore) {
    const before = notifs.length;
    const valid  = notifs.filter(n => !n.expires_at || n.expires_at > now);
    notifs.length = 0;
    notifs.push(...valid);
  }
}, 3600_000);

