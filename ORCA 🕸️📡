// OWNER COMMANDS EXECUTOR — Extended KING commands (Owner only)
// ════════════════════════════════════════════════════════════════

async function executeOwnerCommand(cmd: any, ownerEmail: string): Promise<{ success: boolean; result: any }> {

  // ── Original commands ─────────────────────────────────────────
  if (cmd.type === "create_incident") {
    createIncident({ title: cmd.title, severity: cmd.severity, trigger: cmd.trigger });
    return { success: true, result: `Incident created: ${cmd.title}` };
  }
  if (cmd.type === "run_simulation") {
    simulateAttack(cmd.scenario || "full");
    return { success: true, result: `Simulation started: ${cmd.scenario}` };
  }
  if (cmd.type === "update_config") {
    (siteConfig as any)[cmd.key] = cmd.value;
    return { success: true, result: `Config updated: ${cmd.key} = ${cmd.value}` };
  }
  if (cmd.type === "add_knowledge") {
    knowledgeBase.push({ id: uuidv4(), agent_id: "KING", topic: cmd.topic, content: cmd.content, language: cmd.language || "Arabic", created_at: new Date().toISOString() });
    return { success: true, result: `Knowledge added: ${cmd.topic}` };
  }

  // ── Customer Management ───────────────────────────────────────
  if (cmd.type === "toggle_customer") {
    const customer = customerDB.get(cmd.email?.toLowerCase());
    if (!customer) return { success: false, result: `Customer not found: ${cmd.email}` };
    customer.active = !customer.active;
    activityTracker.record(ownerEmail, "king:toggle_customer", { email: cmd.email, active: customer.active });
    return { success: true, result: `Customer ${cmd.email} is now ${customer.active ? "ACTIVE" : "DISABLED"}` };
  }
  if (cmd.type === "upgrade_customer") {
    const customer = customerDB.get(cmd.email?.toLowerCase());
    if (!customer) return { success: false, result: `Customer not found: ${cmd.email}` };
    const validPlans = ["basic", "pro", "enterprise"];
    if (!validPlans.includes(cmd.plan)) return { success: false, result: `Invalid plan: ${cmd.plan}` };
    const limits = PLAN_LIMITS[cmd.plan as keyof typeof PLAN_LIMITS];
    customer.plan = cmd.plan; customer.assetsLimit = limits.assets;
    customer.parallelLimit = limits.parallel; customer.apiAccess = limits.apiAccess;
    customer.expiresAt = Date.now() + 30 * 86400_000; customer.active = true;
    activityTracker.record(ownerEmail, "king:upgrade_customer", { email: cmd.email, plan: cmd.plan });
    return { success: true, result: `Customer ${cmd.email} upgraded to ${cmd.plan}` };
  }
  if (cmd.type === "renew_customer") {
    const days = cmd.days || 30;
    const result = renewSubscription(cmd.email, days, ownerEmail);
    if (!result.success) return { success: false, result: result.error };
    activityTracker.record(ownerEmail, "king:renew_customer", { email: cmd.email, days });
    return { success: true, result: `Subscription renewed for ${cmd.email} — ${days} days added` };
  }
  if (cmd.type === "delete_customer") {
    const customer = customerDB.get(cmd.email?.toLowerCase());
    if (!customer) return { success: false, result: `Customer not found: ${cmd.email}` };
    customerDB.delete(cmd.email.toLowerCase());
    apiKeyIndex.delete(customer.apiKey);
    activityTracker.record(ownerEmail, "king:delete_customer", { email: cmd.email });
    return { success: true, result: `Customer ${cmd.email} deleted permanently` };
  }

  // ── Agent Management ──────────────────────────────────────────
  if (cmd.type === "stop_agent") {
    const agent = agentRegistry.get(cmd.agent_id);
    if (!agent) return { success: false, result: `Agent not found: ${cmd.agent_id}` };
    agent.status = "STOPPED" as any;
    activityTracker.record(ownerEmail, "king:stop_agent", { agent_id: cmd.agent_id });
    return { success: true, result: `Agent ${cmd.agent_id} (${agent.name}) stopped` };
  }
  if (cmd.type === "start_agent") {
    const agent = agentRegistry.get(cmd.agent_id);
    if (!agent) return { success: false, result: `Agent not found: ${cmd.agent_id}` };
    agent.status = "IDLE";
    activityTracker.record(ownerEmail, "king:start_agent", { agent_id: cmd.agent_id });
    return { success: true, result: `Agent ${cmd.agent_id} (${agent.name}) started` };
  }
  if (cmd.type === "stop_all_agents") {
    let count = 0;
    for (const [, agent] of agentRegistry) {
      if (agent.id !== "AG-102") { agent.status = "STOPPED" as any; count++; }
    }
    activityTracker.record(ownerEmail, "king:stop_all_agents", { count });
    return { success: true, result: `${count} agents stopped (KING remains active)` };
  }
  if (cmd.type === "start_all_agents") {
    let count = 0;
    for (const [, agent] of agentRegistry) {
      if (agent.status === "STOPPED") { agent.status = "IDLE"; count++; }
    }
    activityTracker.record(ownerEmail, "king:start_all_agents", { count });
    return { success: true, result: `${count} agents restarted` };
  }

  // ── Incident Management ───────────────────────────────────────
  if (cmd.type === "close_incident") {
    const incident = incidentStore.get(cmd.incident_id);
    if (!incident) return { success: false, result: `Incident not found: ${cmd.incident_id}` };
    (incident as any).status = "RESOLVED";
    (incident as any).resolved_at = new Date().toISOString();
    activityTracker.record(ownerEmail, "king:close_incident", { id: cmd.incident_id });
    return { success: true, result: `Incident ${cmd.incident_id} closed` };
  }
  if (cmd.type === "escalate_incident") {
    const incident = incidentStore.get(cmd.incident_id);
    if (!incident) return { success: false, result: `Incident not found: ${cmd.incident_id}` };
    (incident as any).severity = "CRITICAL";
    (incident as any).status   = "IN_PROGRESS";
    activityTracker.record(ownerEmail, "king:escalate_incident", { id: cmd.incident_id });
    return { success: true, result: `Incident ${cmd.incident_id} escalated to CRITICAL` };
  }

  // ── IOC Management ────────────────────────────────────────────
  if (cmd.type === "add_ioc") {
    if (!cmd.value || !cmd.ioc_type) return { success: false, result: "value and ioc_type required" };
    iocStore.set(cmd.value.toLowerCase(), {
      id: uuidv4(), value: cmd.value, type: cmd.ioc_type,
      confidence: cmd.confidence || 0.9, source: "KING_OWNER_CMD",
      description: cmd.description || "Added by KING on owner request",
      tags: cmd.tags || ["owner-added"], added_by: ownerEmail,
      created_at: new Date().toISOString(), last_seen: new Date().toISOString(), hit_count: 0,
    });
    activityTracker.record(ownerEmail, "king:add_ioc", { value: cmd.value, type: cmd.ioc_type });
    return { success: true, result: `IOC added: ${cmd.value} (${cmd.ioc_type})` };
  }
  if (cmd.type === "delete_ioc") {
    const existed = iocStore.delete(cmd.value?.toLowerCase());
    activityTracker.record(ownerEmail, "king:delete_ioc", { value: cmd.value });
    return { success: existed, result: existed ? `IOC deleted: ${cmd.value}` : `IOC not found: ${cmd.value}` };
  }

  // ── System Control ────────────────────────────────────────────
  if (cmd.type === "flush_cache") {
    const flushed = Object.values(orcaCache).reduce((a, c) => a + c.flush(), 0);
    activityTracker.record(ownerEmail, "king:flush_cache", { flushed });
    return { success: true, result: `Cache flushed — ${flushed} entries cleared` };
  }
  if (cmd.type === "save_db") {
    orcaDB.save();
    return { success: true, result: `Database saved at ${new Date().toISOString()}` };
  }
  if (cmd.type === "clear_old_alerts") {
    const days = cmd.days || 7;
    const cutoff = Date.now() - days * 86400_000;
    const before = alertStore.length;
    const keep = alertStore.filter((a: any) => new Date(a.timestamp).getTime() > cutoff);
    alertStore.length = 0; alertStore.push(...keep);
    activityTracker.record(ownerEmail, "king:clear_alerts", { cleared: before - keep.length, days });
    return { success: true, result: `Cleared ${before - keep.length} alerts older than ${days} days` };
  }
  if (cmd.type === "send_notification") {
    createNotification("king", cmd.notification_type || "info", { message: cmd.message }, cmd.priority || "medium");
    activityTracker.record(ownerEmail, "king:send_notification", { message: cmd.message });
    return { success: true, result: `Notification sent: ${cmd.message}` };
  }
  if (cmd.type === "maintenance_mode") {
    (siteConfig as any).maintenance_mode = cmd.enabled ?? true;
    activityTracker.record(ownerEmail, "king:maintenance_mode", { enabled: cmd.enabled });
    return { success: true, result: `Maintenance mode: ${cmd.enabled ? "ON" : "OFF"}` };
  }
  if (cmd.type === "update_site") {
    const allowed = ["title", "primary_color", "logo", "description", "contact_email", "maintenance_mode"];
    const updated: string[] = [];
    for (const key of allowed) {
      if (cmd[key] !== undefined) { (siteConfig as any)[key] = cmd[key]; updated.push(`${key}=${cmd[key]}`); }
    }
    activityTracker.record(ownerEmail, "king:update_site", { updated });
    return { success: true, result: `Site updated: ${updated.join(", ")}` };
  }

  // ── File Commands ─────────────────────────────────────────────
  if (cmd.type === "analyze_file") {
    const file = fileStore.get(cmd.file_id) as any;
    if (!file) return { success: false, result: `File not found: ${cmd.file_id}` };
    const content = getFileContent(file.id);
    if (!content) return { success: false, result: "File content unavailable" };
    if (file.ext === ".csv") return { success: true, result: analyzeCSV(content.toString("utf-8")) };
    if ([".js",".ts",".py",".sql"].includes(file.ext)) return { success: true, result: analyzeCode(content.toString("utf-8"), file.name) };
    return { success: true, result: { type: "text", lines: content.toString("utf-8").split("\n").length, size: content.length } };
  }
  if (cmd.type === "delete_file") {
    const existed = fileStore.delete(cmd.file_id);
    activityTracker.record(ownerEmail, "king:delete_file", { file_id: cmd.file_id });
    return { success: existed, result: existed ? `File ${cmd.file_id} deleted` : `File not found: ${cmd.file_id}` };
  }

  return { success: false, result: `Unknown command type: ${cmd.type}` };
}

