// SYSTEM 12 — DATA ANALYSIS ENGINE
// ════════════════════════════════════════════════════════════════

// ── Statistical Primitives ────────────────────────────────────
const Stats = {
  mean:       (arr: number[]) => arr.length ? arr.reduce((a,b)=>a+b,0)/arr.length : 0,
  median:     (arr: number[]) => { if(!arr.length)return 0; const s=[...arr].sort((a,b)=>a-b); const m=Math.floor(s.length/2); return s.length%2?s[m]:(s[m-1]+s[m])/2; },
  stddev:     (arr: number[]) => { if(arr.length<2)return 0; const mu=Stats.mean(arr); return Math.sqrt(Stats.mean(arr.map(x=>(x-mu)**2))); },
  percentile: (arr: number[], p: number) => { if(!arr.length)return 0; const s=[...arr].sort((a,b)=>a-b); const idx=(p/100)*(s.length-1); const lo=Math.floor(idx),hi=Math.ceil(idx); return s[lo]+(s[hi]-s[lo])*(idx-lo); },
  outliers:   (arr: number[]) => { const q1=Stats.percentile(arr,25),q3=Stats.percentile(arr,75),iqr=q3-q1; return arr.filter(x=>x<q1-1.5*iqr||x>q3+1.5*iqr); },
  freqMap:    (arr: any[]): Record<string,number> => { const m:Record<string,number>={}; arr.forEach(i=>{const k=String(i);m[k]=(m[k]||0)+1;}); return m; },
  topN:       (freq: Record<string,number>, n=5) => Object.entries(freq).sort((a,b)=>b[1]-a[1]).slice(0,n),
  zscore:     (value: number, mean: number, sd: number) => sd===0?0:(value-mean)/sd,
};

