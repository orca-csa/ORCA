// SYSTEM 07 — RATE LIMITING SYSTEM
// ════════════════════════════════════════════════════════════════

interface RateLimitEntry {
  requests:      number[];   // timestamps
  blocked_until: number | null;
  violations:    number;
}

const rateLimitStore = new Map<string, RateLimitEntry>();

const RATE_CONFIGS = {
  default:   { window_ms: 60_000,  max: 100, block_ms: 300_000,  skip_owner: true  },
  auth:      { window_ms: 900_000, max: 10,  block_ms: 900_000,  skip_owner: false },
  scan:      { window_ms: 60_000,  max: 20,  block_ms: 120_000,  skip_owner: true  },
  api:       { window_ms: 60_000,  max: 60,  block_ms:  60_000,  skip_owner: true  },
  upload:    { window_ms: 60_000,  max: 30,  block_ms:  60_000,  skip_owner: true  },
  chat:      { window_ms: 60_000,  max: 30,  block_ms:  60_000,  skip_owner: true  },
  report:    { window_ms: 60_000,  max: 10,  block_ms: 120_000,  skip_owner: true  },
  code:      { window_ms: 60_000,  max: 20,  block_ms:  60_000,  skip_owner: true  },
  webhook:   { window_ms: 60_000,  max: 50,  block_ms:  60_000,  skip_owner: true  },
};

type RateLimitType = keyof typeof RATE_CONFIGS;

function checkRateLimit(
  key: string,
  config: typeof RATE_CONFIGS.default
): { allowed: boolean; remaining: number; retry_after?: number } {
  const now   = Date.now();
  const entry = rateLimitStore.get(key) || { requests: [], blocked_until: null, violations: 0 };

  if (entry.blocked_until && now < entry.blocked_until) {
    return { allowed: false, remaining: 0, retry_after: Math.ceil((entry.blocked_until - now) / 1000) };
  }

  entry.requests = entry.requests.filter(t => now - t < config.window_ms);
  entry.requests.push(now);

  if (entry.requests.length > config.max) {
    entry.violations++;
    // Progressive blocking: each violation doubles block time
    const blockMs = Math.min(config.block_ms * Math.pow(2, entry.violations - 1), 3600_000);
    entry.blocked_until = now + blockMs;
    entry.requests      = [];
    rateLimitStore.set(key, entry);
    monitoringBus.emit("rate_limit:blocked", { key, violations: entry.violations });
    return { allowed: false, remaining: 0, retry_after: Math.ceil(blockMs / 1000) };
  }

  rateLimitStore.set(key, entry);
  return { allowed: true, remaining: config.max - entry.requests.length };
}

function rateLimitMiddleware(type: RateLimitType = "default") {
  return (req: Request, res: Response, next: NextFunction): void => {
    const config = RATE_CONFIGS[type] || RATE_CONFIGS.default;

    // Skip rate limiting for owners if config allows
    if (config.skip_owner) {
      const tok = req.headers["x-owner-token"] as string;
      if (tok && verifySession(tok)) return next();
    }

    const ip  = getClientIP(req);
    const key = `${type}:${ip}`;
    const result = checkRateLimit(key, config);

    res.setHeader("X-RateLimit-Remaining", result.remaining);
    res.setHeader("X-RateLimit-Type", type);

    if (!result.allowed) {
      res.setHeader("Retry-After", result.retry_after || 60);
      activityTracker.record(ip, "rate_limit:hit", { type });
      res.status(429).json({
        error:       "Rate limit exceeded. Please slow down.",
        type,
        retry_after: result.retry_after,
        hint:        "Upgrade to Pro/Enterprise for higher limits.",
      });
      return;
    }
    next();
  };
}

// Cleanup stale entries every 10 minutes
setInterval(() => {
  const now = Date.now();
  for (const [key, entry] of rateLimitStore) {
    const isExpired  = !entry.blocked_until || now > entry.blocked_until;
    const noRequests = entry.requests.length === 0;
    if (isExpired && noRequests) rateLimitStore.delete(key);
  }
}, 10 * 60_000);

