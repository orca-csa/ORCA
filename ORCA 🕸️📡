type MonitorEvent =
  | "rate_limit:blocked"   | "security:injection_blocked" | "security:ip_blocked"
  | "task:completed"       | "task:failed"
  | "worker:error"
  | "log:critical"         | "error:critical"
  | "sla:breached"         | "incident:created"
  | "ioc:high_confidence"  | "scan:completed"
  | "gateway:error"        | "plugin:error"
  | "db:saved"             | "db:error"
  | "schedule:run"         | "schedule:failed"
  | "customer:expired"     | "customer:created"
  | "webhook:delivered"    | "webhook:failed"
  | string; // open for plugins

interface MonitorListener { id: string; event: MonitorEvent; handler: (data: any) => void; created_at: string; }

const _monitorListeners = new Map<string, MonitorListener[]>();
const _monitorMetrics: Record<string, { count: number; last_at: string }> = {};

// Extend existing monitoringBus with richer API
Object.assign(monitoringBus, {
  onEvent(event: MonitorEvent, handler: (data: any) => void): string {
    const id       = uuidv4();
    const listener: MonitorListener = { id, event, handler, created_at: new Date().toISOString() };
    if (!_monitorListeners.has(event)) _monitorListeners.set(event, []);
    _monitorListeners.get(event)!.push(listener);
    // Also register on core bus
    monitoringBus.on(event, handler);
    return id;
  },
  offEvent(id: string): boolean {
    for (const [, listeners] of _monitorListeners) {
      const idx = listeners.findIndex(l => l.id === id);
      if (idx !== -1) { listeners.splice(idx, 1); return true; }
    }
    return false;
  },
  richMetrics(): Record<string, { count: number; last_at: string }> {
    return { ..._monitorMetrics };
  },
});

// Track rich metrics on every emit
const _origEmit = monitoringBus.emit.bind(monitoringBus);
monitoringBus.emit = function(event: string, data: any = {}): void {
  _monitorMetrics[event] = { count: (_monitorMetrics[event]?.count || 0) + 1, last_at: new Date().toISOString() };
  _origEmit(event, data);
};

