// ── 5. WEBHOOKS ─────────────────────────────────────────────────
interface WebhookConfig {
  id: string; email: string; url: string; secret: string;
  events: string[]; active: boolean; created_at: string;
}

// setWebhook: see full implementation above (with retryOnFail and full fields)

async function fireWebhook(email: string, event: string, payload: any): Promise<boolean> {
  const wh = webhookStore.get(email.toLowerCase());
  if (!wh || !wh.active || !wh.events.includes(event)) return false;
  const body      = JSON.stringify({ event, timestamp: new Date().toISOString(), data: payload });
  const signature = crypto.createHmac("sha256", wh.secret).update(body).digest("hex");
  return new Promise(resolve => {
    try {
      const parsed = new URL(wh.url);
      const lib    = parsed.protocol === "https:" ? https : http;
      const req    = lib.request({
        hostname: parsed.hostname, port: parsed.port || (parsed.protocol === "https:" ? 443 : 80),
        path: parsed.pathname + parsed.search, method: "POST",
        headers: { "Content-Type": "application/json", "Content-Length": Buffer.byteLength(body), "X-ORCA-Event": event, "X-ORCA-Signature": `sha256=${signature}` },
      }, res => { res.resume(); resolve(res.statusCode! < 300); });
      req.setTimeout(8000, () => { req.destroy(); resolve(false); });
      req.on("error", () => resolve(false));
      req.write(body); req.end();
    } catch { resolve(false); }
  });
}

