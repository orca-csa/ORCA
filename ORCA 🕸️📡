function runNuclei(target: string): Promise<string> {
  const safeTarget = sanitizeShellTarget(target);
  return new Promise((resolve, reject) => {
    const { spawn } = require("child_process");
    const proc = spawn("nuclei", ["-u", safeTarget, "-j", "-severity", "critical,high,medium,low", "-silent", "-no-color"], { timeout: 120000 });
    let stdout = "", stderr = "";
    proc.stdout.on("data", (d: Buffer) => { stdout += d.toString(); });
    proc.stderr.on("data", (d: Buffer) => { stderr += d.toString(); });
    proc.on("close", (code: number) => {
      if (code !== 0 && !stdout) reject(new Error(stderr || `nuclei exited with code ${code}`));
      else resolve(stdout || "");
    });
    proc.on("error", (err: Error) => reject(err));
  });
}

function parseNucleiOutput(raw: string): any[] {
  const findings: any[] = [];
  const lines = raw.split("\n").filter(l => l.trim().startsWith("{"));
  for (const line of lines) {
    try {
      const j = JSON.parse(line);
      findings.push({
        id:          uuidv4(),
        type:        "nuclei",
        cve:         j["template-id"] || "",
        severity:    (j.info?.severity || "info").toUpperCase(),
        title:       j.info?.name || j["template-id"],
        url:         j["matched-at"] || "",
        detail:      j.info?.description || "",
        remediation: j.info?.remediation || "Review the vulnerability and apply patch",
        tags:        j.info?.tags || [],
        cvss_score:  j.info?.classification?.["cvss-score"] || null,
        cve_id:      j.info?.classification?.["cve-id"]?.[0] || null,
        source:      "nuclei",
      });
    } catch {}
  }
  return findings;
}

