interface SubscriptionEvent {
  id:         string;
  email:      string;
  event:      "created" | "upgraded" | "downgraded" | "renewed" | "expired" | "cancelled" | "reactivated";
  from_plan:  string | null;
  to_plan:    string | null;
  performed_by: string;
  timestamp:  string;
  notes:      string;
}

const subscriptionEventLog: SubscriptionEvent[] = [];

function logSubscriptionEvent(
  email: string,
  event: SubscriptionEvent["event"],
  fromPlan: string | null,
  toPlan: string | null,
  performedBy: string,
  notes = ""
): SubscriptionEvent {
  const entry: SubscriptionEvent = {
    id: uuidv4(), email, event, from_plan: fromPlan, to_plan: toPlan,
    performed_by: performedBy, timestamp: new Date().toISOString(), notes,
  };
  subscriptionEventLog.push(entry);
  activityTracker.record(performedBy, `subscription:${event}`, { email, from: fromPlan, to: toPlan });
  return entry;
}

function renewSubscription(email: string, days = 30, performedBy = "system"): { success: boolean; error?: string; customer?: any } {
  const customer = customerDB.get(email.toLowerCase());
  if (!customer) return { success: false, error: "Customer not found" };
  const prevPlan  = customer.plan;
  customer.expiresAt = (customer.expiresAt && customer.expiresAt > Date.now())
    ? customer.expiresAt + days * 86400_000
    : Date.now() + days * 86400_000;
  customer.active          = true;
  customer.payment_status  = "paid";
  logSubscriptionEvent(email, "renewed", prevPlan, prevPlan, performedBy, `Extended by ${days} days`);
  return { success: true, customer };
}

function cancelSubscription(email: string, performedBy: string): { success: boolean; error?: string } {
  const customer = customerDB.get(email.toLowerCase());
  if (!customer) return { success: false, error: "Customer not found" };
  const prevPlan = customer.plan;
  customer.active         = false;
  customer.payment_status = "failed";
  logSubscriptionEvent(email, "cancelled", prevPlan, null, performedBy);
  return { success: true };
}

function getSubscriptionStats(): any {
  const customers = Array.from(customerDB.values());
  const now       = Date.now();
  const expiringSoon = customers.filter(c => c.active && c.expiresAt && c.expiresAt - now < 7 * 86400_000);
  return {
    total:          customers.length,
