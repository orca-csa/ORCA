// SYSTEM 08 — REQUEST VALIDATION LAYER
// ════════════════════════════════════════════════════════════════

type FieldType = "string" | "number" | "boolean" | "array" | "object" | "email" | "ip" | "url" | "uuid";

interface FieldSchema {
  type:     FieldType;
  required?: boolean;
  min?:     number;
  max?:     number;
  pattern?: RegExp;
  enum?:    any[];
  default?: any;
}

interface ValidationSchema {
  [field: string]: FieldSchema;
}

interface ValidationResult {
  valid:   boolean;
  errors:  string[];
  cleaned: Record<string, any>;
}

function validateField(key: string, value: any, schema: FieldSchema): { errors: string[]; cleaned: any } {
  const errors: string[] = [];

  // Handle missing values
  if (value === undefined || value === null || value === "") {
    if (schema.required) { errors.push(`${key} is required`); return { errors, cleaned: value }; }
    return { errors, cleaned: schema.default !== undefined ? schema.default : value };
  }

  let cleaned = value;

  // Type validation
  switch (schema.type) {
    case "email":
      if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(value)) errors.push(`${key} must be a valid email`);
      else cleaned = value.toLowerCase().trim();
      break;
    case "ip":
      if (!/^(\d{1,3}\.){3}\d{1,3}$/.test(value)) errors.push(`${key} must be a valid IPv4`);
      break;
    case "url":
      try { new URL(value); } catch { errors.push(`${key} must be a valid URL`); }
      break;
    case "uuid":
      if (!/^[0-9a-f]{8}-[0-9a-f]{4}-4[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$/i.test(value))
        errors.push(`${key} must be a valid UUID`);
      break;
    case "string":
      if (typeof value !== "string") errors.push(`${key} must be a string`);
      else cleaned = value.trim();
      break;
    case "number":
      const n = Number(value);
      if (isNaN(n)) errors.push(`${key} must be a number`);
      else cleaned = n;
      break;
    case "boolean":
      if (typeof value !== "boolean") {
        if (value === "true")  { cleaned = true;  break; }
        if (value === "false") { cleaned = false; break; }
        errors.push(`${key} must be a boolean`);
      }
      break;
    case "array":
      if (!Array.isArray(value)) errors.push(`${key} must be an array`);
      break;
    case "object":
      if (typeof value !== "object" || Array.isArray(value)) errors.push(`${key} must be an object`);
      break;
  }

  // Range / length validation
  if (!errors.length) {
    if (schema.min !== undefined && typeof cleaned === "string" && cleaned.length < schema.min)
      errors.push(`${key} must be at least ${schema.min} characters`);
    if (schema.max !== undefined && typeof cleaned === "string" && cleaned.length > schema.max)
      errors.push(`${key} max length is ${schema.max} characters`);
    if (schema.min !== undefined && typeof cleaned === "number" && cleaned < schema.min)
      errors.push(`${key} must be >= ${schema.min}`);
    if (schema.max !== undefined && typeof cleaned === "number" && cleaned > schema.max)
      errors.push(`${key} must be <= ${schema.max}`);
    if (schema.pattern && typeof cleaned === "string" && !schema.pattern.test(cleaned))
      errors.push(`${key} format is invalid`);
    if (schema.enum && !schema.enum.includes(cleaned))
      errors.push(`${key} must be one of: ${schema.enum.join(", ")}`);
  }

  return { errors, cleaned };
}

function validateData(data: Record<string, any>, schema: ValidationSchema): ValidationResult {
  const allErrors: string[] = [];
  const cleaned: Record<string, any> = {};

  for (const [key, fieldSchema] of Object.entries(schema)) {
    const { errors, cleaned: c } = validateField(key, data[key], fieldSchema);
    allErrors.push(...errors);
    if (c !== undefined && c !== null) cleaned[key] = c;
  }

  return { valid: allErrors.length === 0, errors: allErrors, cleaned };
}

function validateBody(schema: ValidationSchema) {
  return (req: Request, res: Response, next: NextFunction): void => {
    const result = validateData(req.body || {}, schema);
    if (!result.valid) {
      res.status(400).json({ error: "Validation failed", details: result.errors });
      return;
    }
    (req as any).validated = result.cleaned;
    next();
  };
}

