function extractFindings(scan_type: string, result: any): any[] {
  if (scan_type === "vuln_scan") return result?.findings || [];
  if (scan_type === "ioc_external") {
    const sev = result?.abuseipdb?.severity || result?.virustotal?.severity || "LOW";
