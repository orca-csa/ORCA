interface PluginDefinition {
  id?:         string;
  name:        string;
  version:     string;
  description: string;
  author:      string;
  hooks?:      Record<string, (data: any) => Promise<any> | any>;
  config?:     Record<string, any>;
  routes?:     Array<{ method: string; path: string; handler: (req: Request, res: Response) => void }>;
}

interface Plugin extends Required<Omit<PluginDefinition,"id">> {
  id:          string;
  enabled:     boolean;
  loaded_at:   string;
  hook_count:  number;
  error_count: number;
}

const pluginRegistry = new Map<string, Plugin>();
const pluginHooks    = new Map<string, Array<(data: any) => any>>();

function registerPlugin(def: PluginDefinition): Plugin {
  const id      = def.id || def.name.toLowerCase().replace(/[^a-z0-9]/g,"-");
  const plugin: Plugin = {
    id, name:def.name, version:def.version, description:def.description,
    author:def.author, enabled:true,
    hooks:  def.hooks  || {},
    config: def.config || {},
    routes: def.routes || [],
    loaded_at:   new Date().toISOString(),
    hook_count:  Object.keys(def.hooks||{}).length,
    error_count: 0,
  };
  pluginRegistry.set(id, plugin);

  // Register hooks
  for (const [event, handler] of Object.entries(plugin.hooks)) {
    if (!pluginHooks.has(event)) pluginHooks.set(event, []);
    pluginHooks.get(event)!.push(async (data:any) => {
      try { return await handler(data); }
      catch(e) { plugin.error_count++; monitoringBus.emit("plugin:error",{plugin_id:id,event,error:String(e)}); }
    });
    monitoringBus.on(event, handler);
  }

  // Register routes
  for (const route of plugin.routes) {
    const method = route.method.toLowerCase() as "get"|"post"|"put"|"delete"|"patch";
    if (app[method]) {
      (app[method] as any)(`/api/plugins/${id}${route.path}`, route.handler);
      orcaLog("DEBUG","plugin",`Route registered: ${route.method} /api/plugins/${id}${route.path}`);
    }
  }

  orcaLog("INFO","plugin",`Plugin loaded: ${plugin.name} v${plugin.version}`);
  return plugin;
}

function unloadPlugin(id: string): boolean {
  const p = pluginRegistry.get(id);
  if (!p) return false;
  p.enabled = false;
  for(const [event, handlers] of pluginHooks) {
    const filtered = handlers.filter(h => !Object.values(p.hooks).some(ph => ph === h));
    pluginHooks.set(event, filtered);
  }
  orcaLog("INFO","plugin",`Plugin unloaded: ${p.name}`);
  return true;
}

async function triggerPluginHook(event: string, data: any): Promise<any[]> {
  const handlers = pluginHooks.get(event) || [];
  const results: any[] = [];
  for (const h of handlers) { try { results.push(await h(data)); } catch {} }
  return results;
}

