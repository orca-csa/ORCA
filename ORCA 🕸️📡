type LogLevel = "DEBUG" | "INFO" | "WARN" | "ERROR" | "CRITICAL";

interface LogEntry {
  id:        string;
  level:     LogLevel;
  source:    string;
  message:   string;
  data:      any;
  timestamp: string;
}

const LOG_DIR  = pathMod.join(process.cwd(), "orca_logs");
const logStore: LogEntry[] = [];
const MAX_LOGS = 10_000;

try { fs.mkdirSync(LOG_DIR, { recursive: true }); } catch {}

const LOG_LEVEL_WEIGHT: Record<LogLevel, number> = { DEBUG:0, INFO:1, WARN:2, ERROR:3, CRITICAL:4 };
const MIN_LOG_LEVEL: LogLevel = (process.env.LOG_LEVEL as LogLevel) || "INFO";

function orcaLog(level: LogLevel, source: string, message: string, data: any = null): void {
  if (LOG_LEVEL_WEIGHT[level] < LOG_LEVEL_WEIGHT[MIN_LOG_LEVEL]) return;

  const entry: LogEntry = { id: uuidv4(), level, source, message, data, timestamp: new Date().toISOString() };
  logStore.push(entry);
  if (logStore.length > MAX_LOGS) logStore.shift();

  const line = `[${entry.timestamp}] [${level.padEnd(8)}] [${source}] ${message}${data ? " | " + JSON.stringify(data) : ""}`;

  // Console output
  if (level === "CRITICAL" || level === "ERROR") console.error(line);
  else if (level === "WARN")  console.warn(line);

  // File output for WARN+
  if (LOG_LEVEL_WEIGHT[level] >= LOG_LEVEL_WEIGHT["WARN"]) {
    try {
      const date    = new Date().toISOString().slice(0, 10);
      const logFile = pathMod.join(LOG_DIR, `orca_${date}.log`);
      fs.appendFileSync(logFile, line + "\n");
    } catch {}
  }

  if (level === "CRITICAL") monitoringBus.emit("log:critical", entry);
}

// Log rotation — keep only last 7 days of log files
setInterval(() => {
  try {
    const cutoff = Date.now() - 7 * 86400_000;
    const files  = fs.readdirSync(LOG_DIR);
    for (const file of files) {
      const fp   = pathMod.join(LOG_DIR, file);
      const stat = fs.statSync(fp);
      if (stat.mtimeMs < cutoff) { try { fs.unlinkSync(fp); } catch {} }
    }
  } catch {}
}, 24 * 60 * 60_000);

