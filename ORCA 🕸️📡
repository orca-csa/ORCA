// ── IP Blocklist ──────────────────────────────────────────────
const ipBlocklist  = new Set<string>();
const ipAllowlist  = new Set<string>();

function blockIP(ip: string, reason: string, addedBy: string): void {
  ipBlocklist.add(ip);
  activityTracker.record(addedBy, "security:ip_blocked", { ip, reason });
  orcaLog("WARN", "security", `IP blocked: ${ip}`, { reason });
}

function unblockIP(ip: string, removedBy: string): boolean {
  const removed = ipBlocklist.delete(ip);
  if (removed) activityTracker.record(removedBy, "security:ip_unblocked", { ip });
  return removed;
}

// ── Security Headers ──────────────────────────────────────────
function securityHeadersMiddleware(_req: Request, res: Response, next: NextFunction): void {
  res.setHeader("X-Content-Type-Options",    "nosniff");
  res.setHeader("X-Frame-Options",           "DENY");
  res.setHeader("X-XSS-Protection",          "1; mode=block");
  res.setHeader("Referrer-Policy",           "strict-origin-when-cross-origin");
  res.setHeader("Permissions-Policy",        "geolocation=(), microphone=(), camera=()");
  res.setHeader("X-Powered-By-ORCA",         "v5.0.0");
  res.removeHeader("X-Powered-By");
  next();
}

// ── CORS Middleware ───────────────────────────────────────────
function corsMiddleware(req: Request, res: Response, next: NextFunction): void {
  const allowed = process.env.ALLOWED_ORIGIN || "*";
  res.setHeader("Access-Control-Allow-Origin",  allowed);
  res.setHeader("Access-Control-Allow-Methods", "GET,POST,PATCH,PUT,DELETE,OPTIONS");
  res.setHeader("Access-Control-Allow-Headers", "Content-Type,Authorization,X-Owner-Token,X-Api-Key,X-Service-Key");
  res.setHeader("Access-Control-Max-Age",       "86400");
  if (req.method === "OPTIONS") { res.sendStatus(204); return; }
  next();
}

// ── Request Sanitizer ─────────────────────────────────────────
function sanitizeMiddleware(req: Request, res: Response, next: NextFunction): void {
  const ip = getClientIP(req);

  // IP blocklist check
  if (ipBlocklist.has(ip)) {
    orcaLog("WARN", "security", `Blocked request from: ${ip}`, { path: req.path });
    res.status(403).json({ error: "Access denied" });
    return;
  }

  // Body size check
  const contentLength = parseInt(req.headers["content-length"] || "0");
  if (contentLength > 50 * 1024 * 1024) {
    res.status(413).json({ error: "Request body too large (max 50MB)" });
    return;
  }

  // Injection pattern check
  const combined = JSON.stringify(req.body || {}) + JSON.stringify(req.query || {});
  const injectionPatterns = [
    /<script[\s>]/i,
    /javascript:/i,
    /on\w+\s*=/i,
    /union\s+select/i,
    /\bexec\s*\(/i,
    /\$where\s*:/i,      // NoSQL injection
    /\$gt.*\$lt/,        // MongoDB operator injection
    /\.\.\//,            // Path traversal
  ];
  for (const pattern of injectionPatterns) {
    if (pattern.test(combined)) {
      orcaLog("WARN", "security", "Injection attempt blocked", { ip, path: req.path, pattern: pattern.toString() });
      monitoringBus.emit("security:injection_blocked", { ip, path: req.path });
      // Auto-increment violation counter; block if >= 5 violations
      const key      = `security_violations:${ip}`;
      const entry    = rateLimitStore.get(key) || { requests: [], blocked_until: null, violations: 0 };
      entry.violations++;
      if (entry.violations >= 5) {
        blockIP(ip, "Repeated injection attempts", "auto-security");
      }
      rateLimitStore.set(key, entry);
      res.status(400).json({ error: "Request blocked by security filter" });
      return;
    }
  }

  next();
}

// ── JWT-style Bearer Token Support ───────────────────────────
function bearerAuthMiddleware(req: Request, _res: Response, next: NextFunction): void {
  const auth = req.headers["authorization"] as string;
  if (auth?.startsWith("Bearer ")) {
    const tok = auth.slice(7);
    // Map Bearer token to X-Owner-Token header format internally
    if (!req.headers["x-owner-token"]) {
      (req.headers as any)["x-owner-token"] = tok;
    }
  }
  next();
}

// ── Customer API Key guard (enhanced) ────────────────────────
function customerKeyMiddleware(req: Request, res: Response, next: NextFunction): void {
  const key = (req.headers["x-api-key"] as string) || req.query.api_key as string;
  if (!key) { res.status(401).json({ error: "X-Api-Key header required" }); return; }
  const customer = validateCustomerKey(key);
  if (!customer) { res.status(403).json({ error: "Invalid or expired API key" }); return; }
  if (!customer.apiAccess) { res.status(403).json({ error: "API access requires Pro or Enterprise plan" }); return; }
  if (customer.assetsUsed >= customer.assetsLimit) { res.status(429).json({ error: `Asset quota exceeded. Limit: ${customer.assetsLimit}/month. Upgrade your plan.` }); return; }
  (req as any).customer = customer;
  activityTracker.record(customer.email, "api:request", { path: req.path, method: req.method });
  next();
}

// ── Feature Auth (Customer or Owner) ─────────────────────────
function getEmailFromRequest(req: Request): string | null {
  const ownerTok = req.headers["x-owner-token"] as string;
  if (ownerTok) { const e = verifySession(ownerTok); if (e && isOwner(e)) return e; }
  const apiKey   = (req.headers["x-api-key"] as string) || req.query.api_key as string;
  if (apiKey) {
    const email = apiKeyIndex.get(apiKey);
    if (email) { const c = customerDB.get(email); if (c?.active) return c.email; }
  }
  return null;
}

function requireFeatureAuth(req: Request, res: Response): string | null {
  const email = getEmailFromRequest(req);
  if (!email) { res.status(401).json({ error: "X-Api-Key or X-Owner-Token required" }); return null; }
  return email;
}

