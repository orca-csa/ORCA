// Helper: resolve engine function by service id
async function runEngine(serviceId: string, target: string): Promise<any> {
  switch (serviceId) {
    case "1": return engine1_websiteSecurity(target);
    case "2": return engine2_domainInfrastructure(target);
    case "3": return engine3_threatAttack(target);
    case "4": return engine4_aiIntelligence(target);
    default:  throw new Error(`Unknown service id: ${serviceId}`);
  }
}

