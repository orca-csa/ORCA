function detectLanguage(fileName: string, content: string): string {
  const ext = pathMod.extname(fileName).toLowerCase();
  const map: Record<string,string> = { ".js":"javascript",".jsx":"javascript",".mjs":"javascript",".ts":"typescript",".tsx":"typescript",".py":"python",".sql":"sql",".sh":"shell",".bash":"shell",".html":"html",".xml":"xml",".yaml":"yaml",".yml":"yaml" };
  if (map[ext]) return map[ext];
  if (content.includes("#!/usr/bin/env python") || content.includes("#!/usr/bin/python")) return "python";
  if (content.includes("#!/bin/bash") || content.includes("#!/bin/sh")) return "shell";
  return "unknown";
}

function analyzeCode(content: string, fileName = "unknown.txt"): CodeAnalysisResult {
  const language   = detectLanguage(fileName, content);
  const lines      = content.split("\n");
  const blankLines = lines.filter(l => l.trim() === "").length;
  const commentLines = lines.filter(l => /^\s*(\/\/|#|\/\*|\*|--|\*\/)/.test(l)).length;
  const findings: CodeFinding[] = [];

  for (const rule of CODE_RULES) {
    lines.forEach((line, idx) => {
      if (rule.p.test(line)) {
        findings.push({
          id:          uuidv4(),
          rule_id:     rule.id,
          severity:    rule.sev,
          category:    rule.category,
          message:     rule.msg,
          line:        idx + 1,
          col:         line.search(rule.p) + 1,
          snippet:     line.trim().slice(0, 120),
          remediation: rule.fix,
          cwe:         rule.cwe,
          owasp:       rule.owasp,
        });
      }
    });
  }

  // Deduplicate (same rule_id on adjacent lines → keep first)
  const deduped: CodeFinding[] = [];
  const seen = new Map<string, number>();
  for (const f of findings) {
    const key   = `${f.rule_id}`;
    const lastLine = seen.get(key) || -99;
    if (f.line !== null && f.line - lastLine < 3) continue; // skip near-duplicate
    deduped.push(f);
    seen.set(key, f.line || 0);
  }

  const summary: Record<string, number> = { CRITICAL:0, HIGH:0, MEDIUM:0, LOW:0, INFO:0 };
  for (const f of deduped) summary[f.severity] = (summary[f.severity]||0) + 1;

  const riskScore = Math.min(100,
    (summary.CRITICAL||0)*25 + (summary.HIGH||0)*10 +
    (summary.MEDIUM||0)*5   + (summary.LOW||0)*2
  );

  const complexity = riskScore >= 75 ? "critical" : riskScore >= 50 ? "high" : riskScore >= 25 ? "medium" : "low";

  return {
    file_name: fileName, language,
    lines:         lines.length,
    blank_lines:   blankLines,
    comment_lines: commentLines,
    findings:      deduped,
    summary, risk_score: riskScore, complexity,
    analyzed_at: new Date().toISOString(),
  };
}

