function analyzeSecurityMetrics(timeframe_hours = 24): any {
  const cutoff       = Date.now() - timeframe_hours * 3600_000;
  const recentAlerts = alertStore.filter((a:any) => new Date(a.timestamp||0).getTime() > cutoff);
  const allIncs      = Array.from(incidentStore.values()) as any[];
  const resolvedIncs = allIncs.filter(i => i.status==="RESOLVED" && i.created_at && i.updated_at);
  const mttr         = resolvedIncs.map(i => (new Date(i.updated_at).getTime()-new Date(i.created_at).getTime())/3600_000);
  const iocConfs     = Array.from(iocStore.values()).map((i:any) => i.confidence||0);
  const allScans     = Array.from(scanHistoryStore.values()) as any[];
  const scanDurs     = allScans.filter(s=>s.result?.duration_ms).map(s=>s.result.duration_ms);
  const gatewayRecent= gatewayLogs.slice(-500);

  return {
    timeframe_hours,
    generated_at: new Date().toISOString(),
    alerts: {
      total:       recentAlerts.length,
      by_type:     Stats.freqMap(recentAlerts.map((a:any)=>a.type||"unknown")),
      by_severity: Stats.freqMap(recentAlerts.map((a:any)=>a.severity||"unknown")),
      top_sources: Stats.topN(Stats.freqMap(recentAlerts.map((a:any)=>a.src_ip||"unknown"))),
    },
    incidents: {
      total:          allIncs.length,
      open:           allIncs.filter(i=>i.status==="OPEN").length,
      sla_breached:   allIncs.filter(i=>i.sla_breached).length,
      by_severity:    Stats.freqMap(allIncs.map(i=>i.severity)),
      mttr_hours:     {
        mean:   +Stats.mean(mttr).toFixed(2),
        median: +Stats.median(mttr).toFixed(2),
        p95:    +Stats.percentile(mttr,95).toFixed(2),
        stddev: +Stats.stddev(mttr).toFixed(2),
      },
    },
    iocs: {
      total:      iocStore.size,
      by_type:    Stats.freqMap(Array.from(iocStore.values()).map((i:any)=>i.type)),
      confidence: {
        mean:     +Stats.mean(iocConfs).toFixed(3),
        stddev:   +Stats.stddev(iocConfs).toFixed(3),
        low_conf: iocConfs.filter(c=>c<0.5).length,
        high_conf:iocConfs.filter(c=>c>=0.8).length,
        outliers: Stats.outliers(iocConfs).length,
      },
    },
    scans: {
      total:        allScans.length,
      by_type:      Stats.freqMap(allScans.map(s=>s.scan_type)),
      avg_duration: +Stats.mean(scanDurs).toFixed(0),
      p95_duration: +Stats.percentile(scanDurs,95).toFixed(0),
    },
    tasks: {
      total:          taskMetrics.total,
      completed:      taskMetrics.completed,
      failed:         taskMetrics.failed,
      cancelled:      taskMetrics.cancelled,
      success_rate:   taskMetrics.total>0 ? +((taskMetrics.completed/taskMetrics.total)*100).toFixed(1) : 0,
      avg_duration:   taskMetrics.avg_duration_ms,
      throughput_1min:taskMetrics.throughput_per_min,
    },
    gateway: {
      total_requests:  gatewayRecent.length,
      avg_latency_ms:  +Stats.mean(gatewayRecent.map(g=>g.duration_ms)).toFixed(1),
      p95_latency_ms:  +Stats.percentile(gatewayRecent.map(g=>g.duration_ms),95).toFixed(1),
      error_rate_pct:  gatewayRecent.length ? +((gatewayRecent.filter(g=>g.status_code>=500).length/gatewayRecent.length)*100).toFixed(2) : 0,
